---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';
import WhatsAppButton from '@components/WhatsAppButton.astro';
import { seoData } from '@data/seo';

const seo = seoData['gracias'];
---

<BaseLayout seo={seo}>
  <Navbar />

  <!-- Success Section -->
  <section class="relative py-16 sm:py-24 lg:py-32 bg-white">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 relative z-10 text-center">
      <!-- Checkmark -->
      <div class="mb-8 flex justify-center">
        <div class="relative">
          <div class="absolute inset-0 bg-[#dc2626] rounded-full animate-ping opacity-20"></div>
          <div class="absolute inset-0 bg-[#dc2626] rounded-full animate-pulse opacity-10"></div>
          <div class="relative bg-[#dc2626] rounded-full w-32 h-32 flex items-center justify-center shadow-2xl">
            <svg class="w-16 h-16" viewBox="0 0 52 52">
              <circle cx="26" cy="26" r="25" fill="none" stroke="white" stroke-width="3"/>
              <path fill="none" stroke="white" stroke-width="4" stroke-linecap="round" d="M14 27l7.5 7.5L38 18"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- Main Message -->
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.1] tracking-tight mb-6">
        <span class="block text-[#0f172a]">¡Mensaje</span>
        <span class="block text-[#dc2626]">Recibido!</span>
      </h1>

      <p class="text-xl text-[#64748b] leading-relaxed mb-8 max-w-2xl mx-auto">
        Gracias por confiar en Starsolution. Su solicitud está siendo procesada por nuestro equipo
        de especialistas.
      </p>

      <!-- Response Badge -->
      <div class="inline-flex items-center gap-3 bg-[#fef2f2] border-2 border-[#dc2626] rounded-full px-6 py-3 mb-8">
        <div class="relative">
          <div class="w-3 h-3 bg-[#dc2626] rounded-full animate-pulse"></div>
          <div class="absolute inset-0 w-3 h-3 bg-[#dc2626] rounded-full animate-ping"></div>
        </div>
        <div class="text-[#0f172a] font-semibold text-sm">
          Respuesta estimada: <span class="text-[#dc2626]">menos de 2 horas</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Next Steps Timeline -->
  <section class="py-16 sm:py-20 bg-[#f9fafb]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4 text-[#0f172a]">¿Qué Sigue Ahora?</h2>
        <p class="text-lg text-[#64748b]">Nuestro proceso de respuesta en 3 pasos simples</p>
      </div>

      <div class="relative">
        <div class="absolute left-8 top-0 bottom-0 w-0.5 bg-[#e5e7eb] hidden md:block"></div>

        <div class="space-y-8">
          <div class="relative flex gap-6 items-start group">
            <div class="flex-shrink-0 w-16 h-16 bg-[#dc2626] rounded-full flex items-center justify-center text-white text-2xl font-bold shadow-lg group-hover:scale-110 transition-transform duration-300 relative z-10">1</div>
            <div class="flex-1 bg-white border border-[#e5e7eb] rounded-xl p-6 group-hover:shadow-lg transition-shadow duration-300">
              <div class="flex items-center gap-3 mb-3">
                <h3 class="text-xl font-bold text-[#0f172a]">Revisión Inmediata</h3>
                <span class="bg-[#fef2f2] text-[#dc2626] text-xs font-bold px-3 py-1 rounded-full">EN PROGRESO</span>
              </div>
              <p class="text-[#64748b] mb-3">Un especialista está revisando su solicitud ahora mismo y preparando una propuesta personalizada basada en sus necesidades específicas.</p>
              <div class="flex items-center gap-2 text-sm text-[#64748b]">
                <svg class="w-4 h-4 text-[#dc2626]" fill="none" viewBox="0 0 24 24">
                  <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Tiempo estimado: 30 minutos
              </div>
            </div>
          </div>

          <div class="relative flex gap-6 items-start group">
            <div class="flex-shrink-0 w-16 h-16 bg-[#0f172a] rounded-full flex items-center justify-center text-white text-2xl font-bold shadow-lg group-hover:scale-110 transition-transform duration-300 relative z-10">2</div>
            <div class="flex-1 bg-white border border-[#e5e7eb] rounded-xl p-6 group-hover:shadow-lg transition-shadow duration-300">
              <div class="flex items-center gap-3 mb-3">
                <h3 class="text-xl font-bold text-[#0f172a]">Contacto Personalizado</h3>
                <span class="bg-[#f9fafb] text-[#64748b] text-xs font-bold px-3 py-1 rounded-full">PRÓXIMAMENTE</span>
              </div>
              <p class="text-[#64748b] mb-3">Recibirá un email o llamada de nuestro equipo con una propuesta técnica detallada, cotización y próximos pasos para su proyecto.</p>
              <div class="flex items-center gap-2 text-sm text-[#64748b]">
                <svg class="w-4 h-4 text-[#64748b]" fill="none" viewBox="0 0 24 24">
                  <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Tiempo estimado: &lt; 2 horas
              </div>
            </div>
          </div>

          <div class="relative flex gap-6 items-start group">
            <div class="flex-shrink-0 w-16 h-16 bg-[#64748b] rounded-full flex items-center justify-center text-white text-2xl font-bold shadow-lg group-hover:scale-110 transition-transform duration-300 relative z-10">3</div>
            <div class="flex-1 bg-white border border-[#e5e7eb] rounded-xl p-6 group-hover:shadow-lg transition-shadow duration-300">
              <div class="flex items-center gap-3 mb-3">
                <h3 class="text-xl font-bold text-[#0f172a]">Reunión Virtual</h3>
                <span class="bg-[#f9fafb] text-[#64748b] text-xs font-bold px-3 py-1 rounded-full">AGENDADA</span>
              </div>
              <p class="text-[#64748b] mb-3">Coordinaremos una videollamada para resolver todas sus dudas, ajustar la propuesta y definir el plan de implementación.</p>
              <div class="flex items-center gap-2 text-sm text-[#64748b]">
                <svg class="w-4 h-4 text-[#64748b]" fill="none" viewBox="0 0 24 24">
                  <path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                A convenir según su disponibilidad
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Resources -->
  <section class="py-16 sm:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4 text-[#0f172a]">Mientras Espera, Explore Nuestros Recursos</h2>
        <p class="text-lg text-[#64748b]">Conozca más sobre nuestras soluciones y casos de éxito</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <a href="/bitdefender" class="group bg-[#f9fafb] border border-[#e5e7eb] rounded-xl p-6 hover:border-[#dc2626] hover:shadow-xl transition-all duration-300">
          <div class="bg-[#fef2f2] rounded-lg w-12 h-12 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6 text-[#dc2626]" fill="none" viewBox="0 0 24 24">
              <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-[#0f172a] group-hover:text-[#dc2626] transition-colors">Bitdefender GravityZone</h3>
          <p class="text-[#64748b] mb-4">Descubra cómo protegemos más de 500 empresas con la tecnología antivirus #1 del mercado.</p>
          <div class="flex items-center gap-2 text-[#dc2626] font-semibold text-sm">
            Ver más
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24">
              <path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </a>

        <a href="/iso27001" class="group bg-[#f9fafb] border border-[#e5e7eb] rounded-xl p-6 hover:border-[#dc2626] hover:shadow-xl transition-all duration-300">
          <div class="bg-[#fef2f2] rounded-lg w-12 h-12 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6 text-[#dc2626]" fill="none" viewBox="0 0 24 24">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-[#0f172a] group-hover:text-[#dc2626] transition-colors">Certificación ISO 27001</h3>
          <p class="text-[#64748b] mb-4">Aprenda sobre nuestro proceso de auditoría y cómo ayudamos a certificar su empresa.</p>
          <div class="flex items-center gap-2 text-[#dc2626] font-semibold text-sm">
            Ver más
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24">
              <path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </a>

        <a href="/cableado-estructurado" class="group bg-[#f9fafb] border border-[#e5e7eb] rounded-xl p-6 hover:border-[#dc2626] hover:shadow-xl transition-all duration-300">
          <div class="bg-[#fef2f2] rounded-lg w-12 h-12 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6 text-[#dc2626]" fill="none" viewBox="0 0 24 24">
              <path d="M13 10V3L4 14h7v7l9-11h-7z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-[#0f172a] group-hover:text-[#dc2626] transition-colors">Cableado Estructurado</h3>
          <p class="text-[#64748b] mb-4">Conozca nuestras soluciones de infraestructura certificada con garantía de 25 años.</p>
          <div class="flex items-center gap-2 text-[#dc2626] font-semibold text-sm">
            Ver más
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24">
              <path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Social Proof -->
  <section class="py-16 sm:py-20 bg-[#0f172a]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4 text-white">Empresas que Confiaron en Nosotros</h2>
        <p class="text-lg text-[#94a3b8]">Más de 500 compañías protegen su infraestructura con Starsolution</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="text-center p-6 bg-[#1e293b] border border-[#334155] rounded-xl hover:border-[#dc2626] transition-colors duration-300">
          <div class="text-4xl sm:text-5xl font-bold text-[#dc2626] mb-2">500+</div>
          <div class="text-sm text-[#94a3b8]">Empresas Protegidas</div>
        </div>
        <div class="text-center p-6 bg-[#1e293b] border border-[#334155] rounded-xl hover:border-[#dc2626] transition-colors duration-300">
          <div class="text-4xl sm:text-5xl font-bold text-[#dc2626] mb-2">98%</div>
          <div class="text-sm text-[#94a3b8]">Satisfacción del Cliente</div>
        </div>
        <div class="text-center p-6 bg-[#1e293b] border border-[#334155] rounded-xl hover:border-[#dc2626] transition-colors duration-300">
          <div class="text-4xl sm:text-5xl font-bold text-[#dc2626] mb-2">15+</div>
          <div class="text-sm text-[#94a3b8]">Años de Experiencia</div>
        </div>
        <div class="text-center p-6 bg-[#1e293b] border border-[#334155] rounded-xl hover:border-[#dc2626] transition-colors duration-300">
          <div class="text-4xl sm:text-5xl font-bold text-[#dc2626] mb-2">24/7</div>
          <div class="text-sm text-[#94a3b8]">Soporte Disponible</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Need Help CTA -->
  <section class="py-16 sm:py-20 bg-[#f9fafb]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="bg-white border-2 border-[#e5e7eb] rounded-2xl p-8 sm:p-12">
        <h2 class="text-2xl sm:text-3xl font-bold mb-4 text-[#0f172a]">¿Necesita Ayuda Inmediata?</h2>
        <p class="text-lg text-[#64748b] mb-8">Si su solicitud es urgente, puede contactarnos directamente por WhatsApp o teléfono</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://wa.me/573007010017" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-[#25D366] text-white px-8 py-4 rounded-lg font-semibold hover:bg-[#20BA5A] transition shadow-lg">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            Chatear Ahora
          </a>
          <a href="tel:+573007010017" class="inline-flex items-center justify-center gap-2 bg-[#0f172a] text-white px-8 py-4 rounded-lg font-semibold hover:bg-[#1e293b] transition shadow-lg">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Llamar Ahora
          </a>
        </div>
        <p class="text-xs text-[#64748b] mt-6">Horario de atención: Lun - Vie 8:00 AM - 6:00 PM | Sáb 9:00 AM - 1:00 PM</p>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-12 bg-white border-t border-[#e5e7eb]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <a href="/" class="inline-flex items-center gap-2 text-[#64748b] hover:text-[#0f172a] transition font-semibold">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24"><path d="M10 19l-7-7m0 0l7-7m-7 7h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Volver al Inicio
      </a>
    </div>
  </section>

  <Footer />
  <WhatsAppButton />
</BaseLayout>
