---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';
import WhatsAppButton from '@components/WhatsAppButton.astro';
import { seoData } from '@data/seo';

const seo = seoData.home;
---

<BaseLayout seo={seo}>
  <Navbar />

  <!-- Hero Section - "Fortalezca Su Seguridad" -->
  <section class="relative overflow-hidden pt-16 sm:pt-24 lg:pt-32 pb-20 sm:pb-32 lg:pb-40 bg-gradient-to-br from-gray-950 via-gray-900 to-black">
    <!-- Grid decorativo -->
    <div class="absolute inset-0 pointer-events-none opacity-10">
      <div class="absolute inset-0" style="background-image: linear-gradient(to right, #6b7280 1px, transparent 1px), linear-gradient(to bottom, #6b7280 1px, transparent 1px); background-size: 60px 60px;"></div>
    </div>

    <!-- Glow effects -->
    <div class="absolute top-20 left-1/4 w-[500px] h-[500px] bg-red-600/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-1/4 w-[500px] h-[500px] bg-blue-600/10 rounded-full blur-3xl"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Left Column - Content -->
        <div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold leading-tight mb-6 text-white">
            Ciberseguridad Empresarial para Proteger su Negocio
          </h1>
          <p class="text-lg sm:text-xl text-gray-300 mb-8 leading-relaxed">
            Protegemos más de 3,000 empresas en Colombia, Venezuela y Estados Unidos con soluciones EDR/XDR, pentesting profesional, ISO 27001 y monitoreo SOC 24/7.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <a href="/contacto" class="bg-white text-gray-900 font-semibold px-8 py-4 rounded-full hover:bg-gray-100 transition shadow-lg text-center">
              Solicitar Consultoría Gratuita
            </a>
            <a href="/informe-ciberseguridad-colombia-2026" class="backdrop-blur-xl bg-white/10 border border-white/20 text-white font-semibold px-8 py-4 rounded-full hover:bg-white/20 transition text-center">
              Ver Informe 2026
            </a>
          </div>

          <!-- Stats -->
          <div class="flex flex-wrap gap-6">
            <div class="backdrop-blur-xl bg-white/10 border border-white/20 rounded-2xl px-6 py-4">
              <div class="text-3xl font-bold text-white mb-1">3,000+</div>
              <div class="text-sm text-gray-400">Empresas Protegidas</div>
            </div>
            <div class="backdrop-blur-xl bg-white/10 border border-white/20 rounded-2xl px-6 py-4">
              <div class="text-3xl font-bold text-white mb-1">
                <span>590K</span>
                <span class="text-red-500">+</span>
              </div>
              <div class="text-sm text-gray-400">Clientes Satisfechos</div>
            </div>
          </div>
        </div>

        <!-- Right Column - Image -->
        <div class="relative flex justify-center lg:justify-end">
          <div class="relative z-10 w-full max-w-md">
            <div class="relative w-full overflow-hidden rounded-3xl shadow-2xl" style="aspect-ratio: 9/16;">
              <img
                src="/assets/hero-ciberseguridad-infraestructura.webp"
                alt="Infraestructura de ciberseguridad empresarial con protección de red y endpoints - Starsolution Colombia"
                class="absolute inset-0 w-full h-full object-cover"
                fetchpriority="high"
                loading="eager"
                width="450"
                height="800"
              />
            </div>
          </div>

          <!-- Decorative elements -->
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[110%] h-[110%] pointer-events-none opacity-30">
            <div class="absolute inset-0 border-2 border-white/10 rounded-full"></div>
            <div class="absolute inset-[8%] border-2 border-white/5 rounded-full"></div>
          </div>

          <!-- Floating badge -->
          <div class="absolute -bottom-6 -left-6 backdrop-blur-xl bg-white/10 border border-white/20 rounded-2xl p-6 shadow-2xl z-20">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-3 h-3 bg-green-500 rounded-full animate-pulse"></div>
              <span class="text-white font-semibold text-sm">Protección Activa</span>
            </div>
            <div class="text-3xl font-bold text-white">24/7</div>
          </div>
        </div>
      </div>

      <!-- Logos de partners -->
      <div class="mt-16 sm:mt-24">
        <p class="text-center text-gray-500 text-sm uppercase tracking-wider mb-8">Partners Tecnológicos de Confianza</p>
        <div class="flex flex-wrap items-center justify-center gap-x-12 gap-y-4">
          <span class="text-gray-400 text-lg font-semibold tracking-wide">Bitdefender</span>
          <span class="text-gray-400 text-lg font-semibold tracking-wide">Kaspersky</span>
          <span class="text-gray-400 text-lg font-semibold tracking-wide">Fortinet</span>
          <span class="text-gray-400 text-lg font-semibold tracking-wide">Hornetsecurity</span>
          <span class="text-gray-400 text-lg font-semibold tracking-wide">Proofpoint</span>
          <span class="text-gray-400 text-lg font-semibold tracking-wide">Stellar Cyber</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Instant Data Protection -->
  <section class="py-16 sm:py-24 lg:py-32 bg-white relative">
    <div class="absolute inset-0 bg-gradient-to-br from-blue-50/30 via-transparent to-red-50/20 pointer-events-none"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Codigo mockup con glassmorphism mejorado -->
        <div class="relative order-2 lg:order-1">
          <div class="backdrop-blur-2xl bg-gradient-to-br from-gray-900/95 to-gray-800/95 border border-gray-700/50 rounded-3xl shadow-2xl overflow-hidden">
            <div class="flex items-center gap-2 px-6 py-4 bg-gray-800/70 backdrop-blur-sm border-b border-gray-700/50">
              <div class="w-3 h-3 rounded-full bg-red-500"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
              <div class="w-3 h-3 rounded-full bg-green-500"></div>
              <span class="ml-4 text-xs text-gray-400">terminal.log</span>
            </div>
            <div class="p-8 font-mono text-sm space-y-3">
              <div class="flex items-center gap-2">
                <span class="text-green-400">&#9679;</span>
                <span class="text-green-400">[INFO]</span>
                <span class="text-gray-300">Sistema de protección activo</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-blue-400">&#9679;</span>
                <span class="text-blue-400">[SCAN]</span>
                <span class="text-gray-300">Analizando 247 endpoints...</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-yellow-400">&#9679;</span>
                <span class="text-yellow-400">[ALERT]</span>
                <span class="text-gray-300">Intento de acceso no autorizado detectado</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-red-400">&#9679;</span>
                <span class="text-red-400">[BLOCK]</span>
                <span class="text-gray-300">IP 192.168.1.xxx bloqueada</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-green-400">&#9679;</span>
                <span class="text-green-400">[OK]</span>
                <span class="text-gray-300">Amenaza neutralizada exitosamente</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-purple-400">&#9679;</span>
                <span class="text-purple-400">[REPORT]</span>
                <span class="text-gray-300">Generando informe de seguridad...</span>
              </div>
            </div>
          </div>

          <!-- Badge flotante mejorado -->
          <div class="absolute -bottom-6 -right-6 backdrop-blur-xl bg-white/90 border border-red-200/50 rounded-2xl shadow-2xl p-6">
            <div class="text-sm text-gray-600 mb-2 font-medium">Amenazas Bloqueadas Hoy</div>
            <div class="text-4xl font-bold bg-gradient-to-r from-red-600 to-red-500 bg-clip-text text-transparent">1,247</div>
            <div class="text-xs text-green-600 mt-1 flex items-center gap-1">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M12 7a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0V8.414l-4.293 4.293a1 1 0 01-1.414 0L8 10.414l-4.293 4.293a1 1 0 01-1.414-1.414l5-5a1 1 0 011.414 0L11 10.586 14.586 7H12z" clip-rule="evenodd" />
              </svg>
              <span>&uarr; 23% vs ayer</span>
            </div>
          </div>
        </div>

        <!-- Contenido -->
        <div class="order-1 lg:order-2">
          <div class="inline-flex items-center gap-2 backdrop-blur-md bg-red-50/80 border border-red-200/50 rounded-full px-4 py-2 mb-6">
            <div class="w-2 h-2 bg-red-500 rounded-full animate-pulse"></div>
            <span class="text-sm font-medium text-red-700 uppercase tracking-wide">Protección Instantánea</span>
          </div>

          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6 text-gray-900 leading-tight">
            Protección de Datos Instantánea
          </h2>

          <p class="text-lg text-gray-600 mb-8 leading-relaxed">
            Nuestra plataforma integrada detecta y neutraliza amenazas en tiempo real,
            protegiendo sus activos críticos las 24 horas del día con tecnología de inteligencia artificial de última generación.
          </p>

          <div class="space-y-4 mb-8">
            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 w-6 h-6 bg-green-100 rounded-full flex items-center justify-center mt-0.5">
                <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900">Detección en Tiempo Real</p>
                <p class="text-sm text-gray-600">Monitoreo continuo 24/7 de todas sus operaciones</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 w-6 h-6 bg-green-100 rounded-full flex items-center justify-center mt-0.5">
                <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900">Respuesta Automática</p>
                <p class="text-sm text-gray-600">Bloqueo inmediato de amenazas identificadas</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 w-6 h-6 bg-green-100 rounded-full flex items-center justify-center mt-0.5">
                <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900">Reportes Inteligentes</p>
                <p class="text-sm text-gray-600">Análisis detallados y recomendaciones accionables</p>
              </div>
            </div>
          </div>

          <a
            href="/contacto"
            class="inline-flex items-center gap-2 backdrop-blur-md bg-gradient-to-r from-red-500 to-red-600 text-white font-semibold px-8 py-4 rounded-full hover:from-red-600 hover:to-red-700 transition shadow-lg"
          >
            Comenzar Ahora
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Comprehensive Facilities Audit - 3 Cards mejoradas -->
  <section class="py-16 sm:py-24 lg:py-32 bg-gradient-to-b from-gray-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <div class="inline-flex items-center gap-2 backdrop-blur-md bg-blue-50/80 border border-blue-200/50 rounded-full px-4 py-2 mb-6">
          <span class="text-sm font-medium text-blue-700 uppercase tracking-wide">Auditoría Integral</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6 text-gray-900">
          Auditoría Integral de Instalaciones
        </h2>
        <p class="text-lg text-gray-600">
          Evaluamos cada aspecto de su infraestructura de seguridad
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Card 1 - Encryption -->
        <div class="group relative backdrop-blur-xl bg-white/70 border border-gray-200/50 rounded-3xl p-8 overflow-hidden hover:shadow-2xl transition-all duration-300 cursor-pointer">
          <div class="absolute inset-0 bg-gradient-to-br from-red-50/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative">
            <div class="backdrop-blur-md bg-gradient-to-br from-red-100/90 to-red-50/80 border border-red-200/50 rounded-3xl p-4 w-fit shadow-lg mb-6">
              <svg class="w-8 h-8 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Encriptación Avanzada</h3>
            <p class="text-gray-600 leading-relaxed mb-6">
              Asegure sus datos con cifrado de nivel empresarial, incluyendo algoritmos AES-256, RSA-4096 y SHA-512 para máxima protección.
            </p>
          </div>
        </div>

        <!-- Card 2 - Audit Logs -->
        <div class="group relative backdrop-blur-xl bg-white/70 border border-gray-200/50 rounded-3xl p-8 overflow-hidden hover:shadow-2xl transition-all duration-300 cursor-pointer">
          <div class="absolute inset-0 bg-gradient-to-br from-blue-50/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative">
            <div class="backdrop-blur-md bg-gradient-to-br from-blue-100/90 to-blue-50/80 border border-blue-200/50 rounded-3xl p-4 w-fit shadow-lg mb-6">
              <svg class="w-8 h-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Registros de Auditoría</h3>
            <p class="text-gray-600 leading-relaxed mb-6">
              Seguimiento completo de toda la actividad con logs detallados que proporcionan trazabilidad total y cumplimiento normativo.
            </p>
          </div>
        </div>

        <!-- Card 3 - Permissions -->
        <div class="group relative backdrop-blur-xl bg-white/70 border border-gray-200/50 rounded-3xl p-8 overflow-hidden hover:shadow-2xl transition-all duration-300 cursor-pointer">
          <div class="absolute inset-0 bg-gradient-to-br from-green-50/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative">
            <div class="backdrop-blur-md bg-gradient-to-br from-green-100/90 to-green-50/80 border border-green-200/50 rounded-3xl p-4 w-fit shadow-lg mb-6">
              <svg class="w-8 h-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Control de Permisos</h3>
            <p class="text-gray-600 leading-relaxed mb-6">
              Gestión granular de permisos para datos cifrados con control de acceso basado en roles (RBAC) y políticas personalizadas.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Seamless Data Compliance -->
  <section class="py-16 sm:py-24 lg:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <div class="inline-flex items-center gap-2 backdrop-blur-md bg-purple-50/80 border border-purple-200/50 rounded-full px-4 py-2 mb-6">
          <span class="text-sm font-medium text-purple-700 uppercase tracking-wide">Cumplimiento</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6 text-gray-900">
          Cumplimiento de Datos Sin Esfuerzo
        </h2>
        <p class="text-lg text-gray-600">
          Garantice el cumplimiento normativo con nuestro framework automatizado
        </p>
      </div>

      <div class="backdrop-blur-xl bg-gradient-to-br from-white/80 to-gray-50/60 border border-gray-200/50 rounded-3xl p-10 sm:p-16 shadow-2xl">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <!-- ISO 27001 -->
          <div class="flex items-start gap-4 p-5 backdrop-blur-md bg-white/60 rounded-2xl border border-gray-200/50 hover:shadow-lg transition-all duration-300 cursor-pointer">
            <div class="flex-shrink-0 w-12 h-12 backdrop-blur-md bg-gradient-to-br from-green-100/90 to-green-50/80 rounded-xl flex items-center justify-center border border-green-200/50">
              <svg class="w-6 h-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            </div>
            <div class="flex-1">
              <h3 class="font-bold text-gray-900 mb-1 text-base">ISO 27001</h3>
              <p class="text-sm text-gray-600">Gestión de Seguridad de la Información</p>
            </div>
          </div>
          <!-- ISO 9001 -->
          <div class="flex items-start gap-4 p-5 backdrop-blur-md bg-white/60 rounded-2xl border border-gray-200/50 hover:shadow-lg transition-all duration-300 cursor-pointer">
            <div class="flex-shrink-0 w-12 h-12 backdrop-blur-md bg-gradient-to-br from-green-100/90 to-green-50/80 rounded-xl flex items-center justify-center border border-green-200/50">
              <svg class="w-6 h-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
            </div>
            <div class="flex-1">
              <h3 class="font-bold text-gray-900 mb-1 text-base">ISO 9001</h3>
              <p class="text-sm text-gray-600">Sistemas de Gestión de Calidad</p>
            </div>
          </div>
          <!-- GDPR -->
          <div class="flex items-start gap-4 p-5 backdrop-blur-md bg-white/60 rounded-2xl border border-gray-200/50 hover:shadow-lg transition-all duration-300 cursor-pointer">
            <div class="flex-shrink-0 w-12 h-12 backdrop-blur-md bg-gradient-to-br from-green-100/90 to-green-50/80 rounded-xl flex items-center justify-center border border-green-200/50">
              <svg class="w-6 h-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <div class="flex-1">
              <h3 class="font-bold text-gray-900 mb-1 text-base">GDPR</h3>
              <p class="text-sm text-gray-600">Protección de Datos Personales EU</p>
            </div>
          </div>
          <!-- SOC 2 Type II -->
          <div class="flex items-start gap-4 p-5 backdrop-blur-md bg-white/60 rounded-2xl border border-gray-200/50 hover:shadow-lg transition-all duration-300 cursor-pointer">
            <div class="flex-shrink-0 w-12 h-12 backdrop-blur-md bg-gradient-to-br from-green-100/90 to-green-50/80 rounded-xl flex items-center justify-center border border-green-200/50">
              <svg class="w-6 h-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
            </div>
            <div class="flex-1">
              <h3 class="font-bold text-gray-900 mb-1 text-base">SOC 2 Type II</h3>
              <p class="text-sm text-gray-600">Controles de Seguridad Auditados</p>
            </div>
          </div>
          <!-- HIPAA -->
          <div class="flex items-start gap-4 p-5 backdrop-blur-md bg-white/60 rounded-2xl border border-gray-200/50 hover:shadow-lg transition-all duration-300 cursor-pointer">
