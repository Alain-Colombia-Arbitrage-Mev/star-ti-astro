---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';
import WhatsAppButton from '@components/WhatsAppButton.astro';
import { seoData } from '@data/seo';

const seo = seoData['brother'];
---

<BaseLayout seo={seo}>
  <Navbar />

  <!-- Hero Section -->
  <section class="relative overflow-hidden pt-20 sm:pt-24 lg:pt-32 pb-16 sm:pb-20 lg:pb-24 bg-gradient-to-br from-blue-50 via-white to-sky-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-blue-100 border border-blue-200 rounded-full px-4 py-2 mb-6">
            <svg class="w-4 h-4 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <span class="text-sm font-semibold text-blue-700 uppercase tracking-wide">Distribuidor Autorizado</span>
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold leading-tight mb-6">
            <span class="block">Impresoras Brother</span>
            <span class="block mt-2 bg-gradient-to-r from-[#0057B8] to-blue-600 bg-clip-text text-transparent">para Empresas en Colombia</span>
          </h1>
          <p class="text-lg sm:text-xl text-gray-600 mb-8 leading-relaxed">Como distribuidor oficial de BROTHER en Colombia, ofrecemos impresoras láser, multifuncionales y escáneres diseñados para la continuidad operativa. Bajo costo por página, garantía de fábrica y soporte técnico especializado.</p>
          <div class="flex flex-col sm:flex-row gap-4 mb-12">
            <a href="/contacto" class="bg-[#0057B8] text-white font-semibold px-8 py-4 rounded-lg shadow-xl hover:bg-blue-700 transition flex items-center justify-center gap-2">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" /></svg>
              Solicitar Catalogo
            </a>
            <a href="/contacto" class="bg-white border-2 border-gray-200 text-gray-700 font-semibold px-8 py-4 rounded-lg shadow-sm hover:bg-gray-50 transition inline-block text-center">Ver Equipos</a>
          </div>
          <div class="grid grid-cols-3 gap-6 pt-8 border-t border-gray-200">
            <div><div class="text-3xl font-bold text-[#0057B8] mb-1">30+</div><div class="text-sm text-gray-600">Años en el mercado</div></div>
            <div><div class="text-3xl font-bold text-[#0057B8] mb-1">99.8%</div><div class="text-sm text-gray-600">Confiabilidad</div></div>
            <div><div class="text-3xl font-bold text-[#0057B8] mb-1">3 años</div><div class="text-sm text-gray-600">Garantía extendida</div></div>
          </div>
        </div>
        <div class="relative">
          <div class="bg-white rounded-2xl shadow-2xl p-12 border border-gray-200">
            <div class="flex items-center justify-center mb-8">
              <svg viewBox="0 0 200 60" class="w-64 h-auto"><text x="10" y="45" font-family="Arial, sans-serif" font-size="48" font-weight="bold" fill="#0057B8">Brother</text></svg>
            </div>
            <div class="space-y-4">
              <div class="flex items-center gap-3 text-gray-700"><svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span class="text-sm">Distribuidor Autorizado en Colombia</span></div>
              <div class="flex items-center gap-3 text-gray-700"><svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span class="text-sm">Stock permanente de equipos y repuestos</span></div>
              <div class="flex items-center gap-3 text-gray-700"><svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span class="text-sm">Soporte técnico especializado</span></div>
              <div class="flex items-center gap-3 text-gray-700"><svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span class="text-sm">Garantía oficial de fábrica</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="absolute top-20 left-10 w-72 h-72 bg-blue-200 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-blob"></div>
    <div class="absolute bottom-20 right-10 w-72 h-72 bg-sky-200 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-blob animation-delay-2000"></div>
  </section>

  <!-- Por Que Brother -->
  <section class="py-16 sm:py-20 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-12 lg:mb-16"><h2 class="text-3xl sm:text-4xl lg:text-5xl font-semibold mb-6">&iquest;Por Qué BROTHER para su Empresa?</h2><p class="text-lg text-gray-600 leading-relaxed">Las impresoras BROTHER están diseñadas para la continuidad operativa. Confiabilidad probada y costos predecibles.</p></div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:shadow-xl transition-shadow duration-300"><div class="bg-blue-50 border border-blue-200 rounded-xl w-14 h-14 flex items-center justify-center mb-6"><svg class="w-7 h-7 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg></div><h3 class="text-xl font-semibold mb-3 text-gray-900">Bajo Costo por Página</h3><p class="text-gray-600 leading-relaxed">Optimización real de costos operativos gracias a consumibles de alto rendimiento. Hasta 70% menos que la competencia.</p></div>
        <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:shadow-xl transition-shadow duration-300"><div class="bg-sky-50 border border-sky-200 rounded-xl w-14 h-14 flex items-center justify-center mb-6"><svg class="w-7 h-7 text-sky-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg></div><h3 class="text-xl font-semibold mb-3 text-gray-900">Impresión Rápida</h3><p class="text-gray-600 leading-relaxed">Velocidades de hasta 50 ppm en blanco y negro y 30 ppm a color. Primera página en menos de 8 segundos.</p></div>
        <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:shadow-xl transition-shadow duration-300"><div class="bg-green-50 border border-green-200 rounded-xl w-14 h-14 flex items-center justify-center mb-6"><svg class="w-7 h-7 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg></div><h3 class="text-xl font-semibold mb-3 text-gray-900">Soporte y Garantía</h3><p class="text-gray-600 leading-relaxed">Garantía oficial de fábrica de 3 años. Soporte técnico especializado en español con tiempos de respuesta garantizados.</p></div>
      </div>
    </div>
  </section>

  <!-- Equipos de Alto Rendimiento -->
  <section class="py-16 sm:py-20 lg:py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 lg:mb-16"><span class="text-sm font-semibold text-blue-600 uppercase tracking-wider">Portafolio Completo</span><h2 class="text-3xl sm:text-4xl lg:text-5xl font-semibold mt-3 mb-6">Equipos de Alto Rendimiento</h2><p class="text-lg text-gray-600 max-w-3xl mx-auto">Desde pequenas oficinas hasta centros de impresion corporativos.</p></div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:shadow-2xl transition-all duration-300">
          <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-xl p-6 mb-6 flex items-center justify-center"><svg class="w-16 h-16 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" /></svg></div>
          <h3 class="text-2xl font-semibold mb-4 text-gray-900">Impresoras Laser</h3>
          <p class="text-gray-600 mb-6">Impresión monocromática y color de alto volumen. Ideales para oficinas que requieren velocidad y bajo costo.</p>
          <ul class="space-y-3 mb-6"><li class="flex items-start gap-2 text-sm text-gray-700"><svg class="w-4 h-4 text-blue-600 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span>Velocidades hasta 50 ppm</span></li><li class="flex items-start gap-2 text-sm text-gray-700"><svg class="w-4 h-4 text-blue-600 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span>Tóner de alto rendimiento (3,000+ páginas)</span></li><li class="flex items-start gap-2 text-sm text-gray-700"><svg class="w-4 h-4 text-blue-600 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span>Conectividad WiFi, Ethernet y USB</span></li></ul>
          <div class="bg-blue-50 border border-blue-100 rounded-lg p-4"><p class="text-sm font-semibold text-blue-900 mb-1">Líneas destacadas:</p><p class="text-sm text-blue-700">HL-L2395DW, HL-L3270CDW, HL-L8360CDW</p></div>
        </div>
        <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:shadow-2xl transition-all duration-300">
          <div class="bg-gradient-to-br from-sky-50 to-sky-100 rounded-xl p-6 mb-6 flex items-center justify-center"><svg class="w-16 h-16 text-sky-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg></div>
          <h3 class="text-2xl font-semibold mb-4 text-gray-900">Multifuncionales</h3>
          <p class="text-gray-600 mb-6">Todo en uno: impresión, copia, escaneo y fax. Optimización de espacio y recursos con calidad Brother.</p>
          <ul class="space-y-3 mb-6"><li class="flex items-start gap-2 text-sm text-gray-700"><svg class="w-4 h-4 text-sky-600 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span>Alimentador automático (ADF)</span></li><li class="flex items-start gap-2 text-sm text-gray-700"><svg class="w-4 h-4 text-sky-600 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span>Escaneo a email, FTP, USB y nube</span></li><li class="flex items-start gap-2 text-sm text-gray-700"><svg class="w-4 h-4 text-sky-600 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span>Pantalla táctil a color intuitiva</span></li></ul>
          <div class="bg-sky-50 border border-sky-100 rounded-lg p-4"><p class="text-sm font-semibold text-sky-900 mb-1">Líneas destacadas:</p><p class="text-sm text-sky-700">MFC-L2750DW, MFC-L3770CDW, MFC-L9570CDW</p></div>
        </div>
        <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:shadow-2xl transition-all duration-300">
          <div class="bg-gradient-to-br from-purple-50 to-purple-100 rounded-xl p-6 mb-6 flex items-center justify-center"><svg class="w-16 h-16 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg></div>
          <h3 class="text-2xl font-semibold mb-4 text-gray-900">Etiquetadoras &amp; Escaneres</h3>
          <p class="text-gray-600 mb-6">Soluciones especializadas para logística, identificación y digitalización de documentos.</p>
          <ul class="space-y-3 mb-6"><li class="flex items-start gap-2 text-sm text-gray-700"><svg class="w-4 h-4 text-purple-600 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span>Etiquetadoras termicas industriales</span></li><li class="flex items-start gap-2 text-sm text-gray-700"><svg class="w-4 h-4 text-purple-600 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span>Escaneres de alto volumen</span></li><li class="flex items-start gap-2 text-sm text-gray-700"><svg class="w-4 h-4 text-purple-600 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg><span>Códigos de barras y QR</span></li></ul>
          <div class="bg-purple-50 border border-purple-100 rounded-lg p-4"><p class="text-sm font-semibold text-purple-900 mb-1">Líneas destacadas:</p><p class="text-sm text-purple-700">PT-P900W, ADS-4700W, TD-4550DNWB</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gestion Integral -->
  <section class="py-16 sm:py-20 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="text-sm font-semibold text-blue-600 uppercase tracking-wider">Más que Equipos</span>
          <h2 class="text-3xl sm:text-4xl font-semibold mt-4 mb-6">Gestión Integral de Impresión Corporativa</h2>
          <p class="text-lg text-gray-600 mb-8">No solo vendemos impresoras. Ofrecemos consultoría, implementación, capacitación y soporte continuo para optimizar su infraestructura de impresión.</p>
          <div class="space-y-6">
            <div class="flex gap-4"><div class="bg-blue-50 rounded-lg p-3 h-fit"><svg class="w-6 h-6 text-blue-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg></div><div><h3 class="font-semibold text-lg mb-2">Auditoría de Impresión</h3><p class="text-gray-600 text-sm">Análisis detallado de su entorno actual y recomendaciones para optimizar costos hasta en un 40%.</p></div></div>
            <div class="flex gap-4"><div class="bg-blue-50 rounded-lg p-3 h-fit"><svg class="w-6 h-6 text-blue-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg></div><div><h3 class="font-semibold text-lg mb-2">Implementación y Configuración</h3><p class="text-gray-600 text-sm">Instalación profesional, configuración de red, integración con Active Directory y políticas de impresión segura.</p></div></div>
            <div class="flex gap-4"><div class="bg-blue-50 rounded-lg p-3 h-fit"><svg class="w-6 h-6 text-blue-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg></div><div><h3 class="font-semibold text-lg mb-2">Monitoreo Proactivo</h3><p class="text-gray-600 text-sm">Supervisión remota de niveles de tóner, alertas preventivas y gestión automatizada de reposición.</p></div></div>
            <div class="flex gap-4"><div class="bg-blue-50 rounded-lg p-3 h-fit"><svg class="w-6 h-6 text-blue-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg></div><div><h3 class="font-semibold text-lg mb-2">Soporte Técnico</h3><p class="text-gray-600 text-sm">Mesa de ayuda especializada con técnicos certificados Brother. Atención prioritaria y visitas on-site.</p></div></div>
          </div>
        </div>
        <div class="space-y-6">
          <div class="bg-gradient-to-br from-blue-600 to-sky-600 rounded-2xl p-8 text-white">
            <h3 class="text-2xl font-semibold mb-6">Por Que Elegirnos</h3>
            <div class="space-y-6">
              <div class="flex items-center gap-4"><div class="bg-white/20 rounded-lg p-3"><svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg></div><div><div class="text-3xl font-bold mb-1">15+</div><div class="text-sm text-blue-100">Años como distribuidor Brother</div></div></div>
