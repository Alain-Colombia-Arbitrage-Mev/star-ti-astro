---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';

const seo = {
  title: 'Pagina No Encontrada | Starsolution',
  description: 'La pagina que busca no existe. Explore nuestras soluciones de ciberseguridad empresarial.',
  keywords: 'error 404, pagina no encontrada',
  canonical: 'https://starsolution.com.co/404',
  noindex: true,
};
---

<BaseLayout seo={seo}>
  <Navbar />

  <section class="min-h-[60vh] flex items-center justify-center bg-gradient-to-br from-gray-50 to-white">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <div class="text-8xl font-bold bg-gradient-to-r from-red-500 to-red-600 bg-clip-text text-transparent mb-6">404</div>
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">Pagina no encontrada</h1>
      <p class="text-lg text-gray-600 mb-8">
        Lo sentimos, la pagina que busca no existe o fue movida. Explore nuestras soluciones de ciberseguridad.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="bg-gray-900 text-white font-semibold px-8 py-4 rounded-full hover:bg-gray-800 transition inline-block text-center">
          Volver al Inicio
        </a>
        <a href="/contacto" class="bg-white border-2 border-gray-300 text-gray-700 font-semibold px-8 py-4 rounded-full hover:bg-gray-50 transition inline-block text-center">
          Contactenos
        </a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
