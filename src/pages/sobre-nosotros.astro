---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';
import WhatsAppButton from '@components/WhatsAppButton.astro';
import { seoData } from '@data/seo';

const seo = seoData['sobre-nosotros'];
---

<BaseLayout seo={seo}>
  <Navbar />

  <!-- Hero Section -->
  <section class="relative py-20 sm:py-28 lg:py-36 bg-gradient-to-br from-[#dc2626] to-[#991b1b] overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 left-0 w-full h-full" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.15) 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>
    <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 px-4 py-2 rounded-full mb-8">
          <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span class="text-white text-xs font-semibold tracking-wider uppercase">+10 años protegiendo empresas en Colombia</span>
        </div>

        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.1] tracking-tight mb-6 text-white">Somos Starsolution</h1>

        <p class="text-xl text-white/90 leading-relaxed mb-10 max-w-3xl mx-auto">
          Especialistas en implementación de soluciones de ciberseguridad y certificaciones ISO 27001.
          Protegemos la información crítica de empresas líderes en Colombia y Latinoamérica.
        </p>

        <!-- Stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20">
            <div class="text-3xl font-bold text-white mb-2">10+</div>
            <div class="text-sm text-white/80">Años de Experiencia</div>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20">
            <div class="text-3xl font-bold text-white mb-2">500+</div>
            <div class="text-sm text-white/80">Clientes Activos</div>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20">
            <div class="text-3xl font-bold text-white mb-2">2,000+</div>
            <div class="text-sm text-white/80">Endpoints Protegidos</div>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20">
            <div class="text-3xl font-bold text-white mb-2">24/7</div>
            <div class="text-sm text-white/80">Soporte Técnico</div>
          </div>
        </div>
        <div class="mt-12 flex justify-center">
          <img
            src="/assets/logo-starsolution-estrella.webp"
            alt="Logo estrella de Starsolution, especialistas en ciberseguridad en Colombia"
            class="w-full max-w-xs mx-auto rounded-2xl shadow-xl"
            width="320"
            height="320"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Quiénes Somos -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-[#fee2e2] border border-[#fecaca] px-4 py-2 rounded-full mb-6">
            <span class="text-[#dc2626] text-xs font-semibold uppercase tracking-wider">Nuestra Historia</span>
          </div>
          <h2 class="text-4xl font-bold text-[#0f172a] mb-6">¿Quiénes Somos?</h2>
          <div class="space-y-4 text-[#64748b] leading-relaxed">
            <p><strong class="text-[#0f172a]">Starsolution S.A.S.</strong> nace en 2013 con el compromiso de elevar los estándares de ciberseguridad en empresas colombianas. Fundada por profesionales certificados en seguridad de la información, nos especializamos en la implementación de soluciones enterprise que protegen activos digitales críticos.</p>
            <p>Hemos evolucionado desde una consultoría boutique hasta convertirnos en <strong class="text-[#0f172a]">partner estratégico de las marcas líderes</strong> en ciberseguridad global: Bitdefender, Kaspersky, Hornet Security, TeamViewer y SOTI. Esta confianza nos permite ofrecer soluciones de clase mundial con soporte local especializado.</p>
            <p>Nuestra experiencia abarca sectores críticos como servicios financieros, salud, retail, manufactura, gobierno y tecnología. Entendemos que <strong class="text-[#0f172a]">cada industria tiene requisitos únicos de compliance y regulación</strong>, por lo que diseñamos arquitecturas de seguridad personalizadas que cumplen con estándares locales e internacionales.</p>
            <p class="text-[#0f172a] font-semibold">No somos solo proveedores de tecnología: somos asesores de confianza que acompañan a nuestros clientes en su transformación digital segura.</p>
          </div>
        </div>

        <!-- Visual -->
        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-4">
            <div class="bg-gradient-to-br from-[#fee2e2] to-[#fecaca] rounded-2xl p-8 aspect-square flex items-center justify-center">
              <svg class="w-20 h-20 text-[#dc2626]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
            <div class="bg-gradient-to-br from-[#f3f4f6] to-[#e5e7eb] rounded-2xl p-8 aspect-square flex flex-col items-center justify-center">
              <div class="text-4xl font-bold text-[#0f172a] mb-2">ISO</div>
              <div class="text-6xl font-bold text-[#dc2626]">27001</div>
              <div class="text-sm text-[#64748b] mt-2">Certified</div>
            </div>
          </div>
          <div class="space-y-4 pt-8">
            <div class="bg-gradient-to-br from-[#dbeafe] to-[#bfdbfe] rounded-2xl p-8 aspect-square flex items-center justify-center">
              <svg class="w-20 h-20 text-[#2563eb]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
            </div>
            <div class="bg-gradient-to-br from-[#fef3c7] to-[#fde68a] rounded-2xl p-8 aspect-square flex items-center justify-center">
              <svg class="w-20 h-20 text-[#f59e0b]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Nuestros Servicios -->
  <section class="py-24 bg-[#f8fafc]">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-[#0f172a] mb-4">Nuestros Servicios</h2>
        <p class="text-lg text-[#64748b] max-w-3xl mx-auto">Soluciones integrales de ciberseguridad diseñadas para proteger cada capa de su infraestructura</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:shadow-xl transition-all duration-300 group cursor-pointer">
          <div class="w-14 h-14 bg-[#fee2e2] rounded-xl flex items-center justify-center mb-6 group-hover:bg-[#dc2626] transition">
            <svg class="w-7 h-7 text-[#dc2626] group-hover:text-white transition" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-[#0f172a] mb-3">Antivirus Empresarial</h3>
          <p class="text-sm text-[#64748b] mb-4 leading-relaxed">Protección endpoint avanzada con Bitdefender GravityZone y Kaspersky Endpoint Security. EDR, XDR y análisis de comportamiento con IA.</p>
          <a href="/antivirus-empresas" class="text-sm text-[#dc2626] font-semibold hover:underline inline-flex items-center gap-2">Ver soluciones <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
        </div>
        <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:shadow-xl transition-all duration-300 group cursor-pointer">
          <div class="w-14 h-14 bg-[#eff6ff] rounded-xl flex items-center justify-center mb-6 group-hover:bg-[#2563eb] transition">
            <svg class="w-7 h-7 text-[#2563eb] group-hover:text-white transition" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-[#0f172a] mb-3">Certificación ISO 27001</h3>
          <p class="text-sm text-[#64748b] mb-4 leading-relaxed">Consultoría integral para implementación y certificación ISO 27001:2022. Gap analysis, documentación SGSI y auditorías internas.</p>
          <a href="/iso27001" class="text-sm text-[#dc2626] font-semibold hover:underline inline-flex items-center gap-2">Conocer más <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
        </div>
        <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:shadow-xl transition-all duration-300 group cursor-pointer">
          <div class="w-14 h-14 bg-[#fff7ed] rounded-xl flex items-center justify-center mb-6 group-hover:bg-[#ea580c] transition">
            <svg class="w-7 h-7 text-[#ea580c] group-hover:text-white transition" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-[#0f172a] mb-3">Seguridad de Email 365</h3>
          <p class="text-sm text-[#64748b] mb-4 leading-relaxed">Hornet Security 365 para protección avanzada de Microsoft 365. Anti-spam, anti-phishing, archivado y cifrado de correo.</p>
          <a href="/hornet-security" class="text-sm text-[#dc2626] font-semibold hover:underline inline-flex items-center gap-2">Ver solución <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
        </div>
        <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:shadow-xl transition-all duration-300 group cursor-pointer">
          <div class="w-14 h-14 bg-[#f0fdf4] rounded-xl flex items-center justify-center mb-6 group-hover:bg-[#16a34a] transition">
            <svg class="w-7 h-7 text-[#16a34a] group-hover:text-white transition" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-[#0f172a] mb-3">Gestión de Dispositivos (MDM)</h3>
          <p class="text-sm text-[#64748b] mb-4 leading-relaxed">SOTI MobiControl para control total de flotas móviles. Android, iOS, Windows. Kiosk mode, geolocalización y políticas de seguridad.</p>
          <a href="/soti-mdm" class="text-sm text-[#dc2626] font-semibold hover:underline inline-flex items-center gap-2">Explorar MDM <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
        </div>
        <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:shadow-xl transition-all duration-300 group cursor-pointer">
          <div class="w-14 h-14 bg-[#fef3c7] rounded-xl flex items-center justify-center mb-6 group-hover:bg-[#f59e0b] transition">
            <svg class="w-7 h-7 text-[#f59e0b] group-hover:text-white transition" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-[#0f172a] mb-3">Acceso Remoto</h3>
          <p class="text-sm text-[#64748b] mb-4 leading-relaxed">TeamViewer para soporte IT remoto y gestión de infraestructura. Control sin restricciones 24/7, sesión recording y autenticación 2FA.</p>
          <a href="/teamviewer" class="text-sm text-[#dc2626] font-semibold hover:underline inline-flex items-center gap-2">Ver detalles <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
        </div>
        <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:shadow-xl transition-all duration-300 group cursor-pointer">
          <div class="w-14 h-14 bg-[#f5f3ff] rounded-xl flex items-center justify-center mb-6 group-hover:bg-[#7c3aed] transition">
            <svg class="w-7 h-7 text-[#7c3aed] group-hover:text-white transition" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-[#0f172a] mb-3">Equipos de Cómputo</h3>
          <p class="text-sm text-[#64748b] mb-4 leading-relaxed">Venta mayorista de computadores empresariales, workstations, laptops gamer y hardware enterprise. Asesoría técnica especializada.</p>
          <a href="/equipos-computo" class="text-sm text-[#dc2626] font-semibold hover:underline inline-flex items-center gap-2">Ver catálogo <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
        </div>
      </div>
    </div>
  </section>

  <!-- Por Qué Elegirnos -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-[#0f172a] mb-4">¿Por Qué Elegir Starsolution?</h2>
        <p class="text-lg text-[#64748b] max-w-3xl mx-auto">Combinamos expertise técnico, partners globales y atención personalizada local</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="text-5xl mb-4">&#127891;</div>
          <h3 class="text-lg font-bold text-[#0f172a] mb-3">Equipo Certificado</h3>
          <p class="text-sm text-[#64748b] leading-relaxed">Ingenieros con certificaciones Bitdefender Expert, Kaspersky Certified, ISO 27001 Lead Implementer y Auditor.</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-4">&#129309;</div>
          <h3 class="text-lg font-bold text-[#0f172a] mb-3">Partners Oficiales</h3>
          <p class="text-sm text-[#64748b] leading-relaxed">Relación directa con fabricantes. Acceso a pricing especial, soporte técnico nivel 3 y versiones beta.</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-4">&#128735;</div>
          <h3 class="text-lg font-bold text-[#0f172a] mb-3">Soporte 24/7</h3>
          <p class="text-sm text-[#64748b] leading-relaxed">Mesa de ayuda con SLA garantizado. Respuesta en menos de 1 hora para incidentes críticos.</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-4">&#128188;</div>
          <h3 class="text-lg font-bold text-[#0f172a] mb-3">Mayoristas IT</h3>
          <p class="text-sm text-[#64748b] leading-relaxed">Especialistas en venta por volumen para integradores y MSPs. Descuentos escalonados y facturación flexible.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contacto y Formulario -->
  <section class="py-24 bg-[#f8fafc]">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-[#0f172a] mb-4">Contáctenos</h2>
        <p class="text-lg text-[#64748b] max-w-3xl mx-auto">Estamos listos para ayudarle a proteger su empresa. Comuníquese con nosotros por cualquiera de estos medios.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Información de Contacto -->
        <div>
          <div class="bg-white border border-gray-200 rounded-2xl p-8 mb-6">
            <h3 class="text-2xl font-bold text-[#0f172a] mb-6">Nuestras Oficinas</h3>
            <div class="space-y-6">
              <div class="bg-[#f8fafc] rounded-xl p-6 border border-gray-200">
                <div class="font-bold text-[#0f172a] mb-1 text-lg">Colombia</div>
                <div class="text-sm text-[#94a3b8] font-semibold uppercase tracking-wide mb-3">Oficina Principal</div>
                <div class="space-y-2 text-sm">
                  <div class="flex items-start gap-2"><span class="text-[#64748b] font-semibold min-w-[80px]">Dirección:</span><span class="text-[#0f172a]">Calle 52 A # 22 – 16<br/>Bogotá - Colombia</span></div>
                  <div class="flex items-start gap-2"><span class="text-[#64748b] font-semibold min-w-[80px]">Teléfono:</span><a href="tel:+573007010017" class="text-[#dc2626] hover:underline font-semibold">+57 300 701 0017</a></div>
                  <div class="flex items-start gap-2"><span class="text-[#64748b] font-semibold min-w-[80px]">Horario:</span><span class="text-[#0f172a]">Lun - Vie: 8:00 AM - 6:00 PM<br/>Sáb: 9:00 AM - 1:00 PM</span></div>
                </div>
              </div>
              <div class="bg-[#f8fafc] rounded-xl p-6 border border-gray-200">
                <div class="font-bold text-[#0f172a] mb-1 text-lg">Venezuela</div>
                <div class="text-sm text-[#94a3b8] font-semibold uppercase tracking-wide mb-3">Oficina Regional</div>
                <div class="space-y-2 text-sm">
                  <div class="flex items-start gap-2"><span class="text-[#64748b] font-semibold min-w-[80px]">Dirección:</span><span class="text-[#0f172a]">Ed. Centro Empresarial<br/>T. Araujo, M. OF A-1<br/>Caracas - Venezuela</span></div>
                  <div class="flex items-start gap-2"><span class="text-[#64748b] font-semibold min-w-[80px]">Teléfono:</span><a href="tel:+584241499856" class="text-[#dc2626] hover:underline font-semibold">+58 424 149 9856</a></div>
                  <div class="flex items-start gap-2"><span class="text-[#64748b] font-semibold min-w-[80px]">Horario:</span><span class="text-[#0f172a]">Lun - Vie: 8:00 AM - 5:00 PM</span></div>
                </div>
              </div>
              <div class="bg-[#f8fafc] rounded-xl p-6 border border-gray-200">
                <div class="font-bold text-[#0f172a] mb-1 text-lg">Estados Unidos</div>
                <div class="text-sm text-[#94a3b8] font-semibold uppercase tracking-wide mb-3">Oficina USA</div>
                <div class="space-y-2 text-sm">
                  <div class="flex items-start gap-2"><span class="text-[#64748b] font-semibold min-w-[80px]">Dirección:</span><span class="text-[#0f172a]">8103 Gables Commons Dr<br/>Orlando, FL 32827 - USA</span></div>
                  <div class="flex items-start gap-2"><span class="text-[#64748b] font-semibold min-w-[80px]">Teléfono:</span><a href="tel:+13214386777" class="text-[#dc2626] hover:underline font-semibold">+1 321 438 6777</a></div>
                  <div class="flex items-start gap-2"><span class="text-[#64748b] font-semibold min-w-[80px]">Horario:</span><span class="text-[#0f172a]">Mon - Fri: 9:00 AM - 6:00 PM EST</span></div>
                </div>
              </div>
              <div class="bg-gradient-to-r from-[#0f172a] to-[#1e293b] rounded-xl p-6 text-white">
