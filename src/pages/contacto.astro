              <h3 class="text-2xl font-bold text-[#0f172a]">Estados Unidos</h3>
            </div>
          </div>
          <div class="space-y-4 mb-6">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#64748b] mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
