---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';
import WhatsAppButton from '@components/WhatsAppButton.astro';
import { seoData } from '@data/seo';

const seo = seoData.anydesk;
---

<BaseLayout seo={seo}>
  <Navbar />

  <div class="bg-white min-h-screen w-full font-['Instrument_Sans',sans-serif]">

    <!-- Hero Section -->
    <section class="relative pt-32 pb-24 lg:pt-40 lg:pb-32 overflow-hidden bg-gradient-to-b from-red-50/30 to-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">

        <!-- Badge -->
        <div class="flex justify-center mb-6">
          <div class="inline-flex items-center gap-2 bg-white border border-red-200 px-4 py-2 rounded-full shadow-sm">
            <span class="text-xs font-bold text-red-700 uppercase tracking-wider">
              RENDIMIENTO EXTREMO
            </span>
          </div>
        </div>

        <!-- Main Heading -->
        <div class="text-center mb-12 max-w-4xl mx-auto">
          <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.1] tracking-tight mb-6">
            <span class="block text-[#0f172a]">El escritorio remoto</span>
            <span class="block text-red-700">más rápido del mundo.</span>
          </h1>
          <p class="text-xl text-[#64748b] leading-relaxed max-w-3xl mx-auto">
            ¿Cansado de lag, congelamiento y conexiones inestables? AnyDesk redefine el control remoto
            con 60 FPS fluidos, latencia inferior a 16ms y una experiencia tan ágil como estar frente al equipo.
          </p>
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
          <a
            href="/contacto"
            class="bg-gradient-to-r from-red-600 to-red-700 text-white font-semibold px-8 py-4 rounded-full hover:from-red-700 hover:to-red-800 transition shadow-lg inline-flex items-center justify-center gap-2"
          >
            Descargar AnyDesk Ahora
          </a>
          <a
            href="#precios"
            class="bg-white border-2 border-gray-200 text-gray-800 font-semibold px-8 py-4 rounded-full hover:bg-gray-50 transition inline-flex items-center justify-center gap-2"
          >
            Solicitar para Empresas
          </a>
        </div>

        <!-- Stats Grid -->
        <div class="max-w-5xl mx-auto">
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
            <div class="bg-white border-2 border-gray-200 rounded-xl p-6 text-center hover:border-[#ed1c24] transition cursor-pointer">
              <div class="text-4xl font-bold text-red-700 mb-2">60 FPS</div>
              <p class="text-sm text-gray-600">Fluidez ultra suave</p>
            </div>
            <div class="bg-white border-2 border-gray-200 rounded-xl p-6 text-center hover:border-blue-500 transition cursor-pointer">
              <div class="text-4xl font-bold text-blue-600 mb-2">&lt; 16 ms</div>
              <p class="text-sm text-gray-600">Latencia mínima</p>
            </div>
            <div class="bg-white border-2 border-gray-200 rounded-xl p-6 text-center hover:border-purple-500 transition cursor-pointer">
              <div class="text-4xl font-bold text-purple-600 mb-2">TLS 1.2</div>
              <p class="text-sm text-gray-600">Cifrado bancario</p>
            </div>
            <div class="bg-white border-2 border-gray-200 rounded-xl p-6 text-center hover:border-green-500 transition cursor-pointer">
              <div class="text-4xl font-bold text-green-600 mb-2">100 kb/s</div>
              <p class="text-sm text-gray-600">Tráfico mínimo</p>
            </div>
          </div>
        </div>

        <!-- Hero Image -->
        <div class="hidden lg:flex items-center justify-center mt-12">
          <img src="/assets/icono-dispositivo-endpoint-security.webp" alt="AnyDesk escritorio remoto empresarial ultra rápido" class="w-full max-w-sm rounded-2xl shadow-xl" width="384" height="384" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- Velocidad Inalcanzable Section -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div>
            <h2 class="text-4xl font-bold text-[#0f172a] mb-6 leading-tight">
              Velocidad Inalcanzable: La Ventaja del Codec DeskRT
            </h2>
            <p class="text-lg text-[#64748b] mb-6 leading-relaxed">
              AnyDesk no es "otro software de control remoto". Su motor grafico propietario <strong class="text-[#0f172a]">DeskRT</strong> comprime,
              transmite y renderiza pantallas a velocidades que rivalizan con conexiones LAN locales.
            </p>

            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 bg-red-700 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div>
                  <h4 class="font-bold text-lg text-[#0f172a] mb-1">60 Frames por Segundo Reales</h4>
                  <p class="text-sm text-[#475569]">
                    Edite videos en Premiere, trabaje en AutoCAD o juegue (sí, es posible) con movimientos fluidos.
                    Competidores tradicionales rondan 15-20 FPS.
                  </p>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <div class="w-6 h-6 bg-red-700 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div>
                  <h4 class="font-bold text-lg text-[#0f172a] mb-1">Latencia Sub-Frame (16ms)</h4>
                  <p class="text-sm text-[#475569]">
                    Desde click del mouse hasta respuesta visual en menos de 1 frame. Ideal para soporte técnico
                    en tiempo real sin retrasos frustrantes.
                  </p>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <div class="w-6 h-6 bg-red-700 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div>
                  <h4 class="font-bold text-lg text-[#0f172a] mb-1">100 KB/s: Funciona en 3G/4G</h4>
                  <p class="text-sm text-[#475569]">
                    Trafico de red 10x menor que VNC/RDP. Acceda a servidores desde hoteles, cafes o
                    conexiones móviles sin buffering constante.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Right - Speed Meter -->
          <div class="bg-gradient-to-br from-gray-900 to-gray-800 rounded-2xl p-12 text-center border-2 border-gray-700">
            <div class="mb-8">
              <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-4">RENDIMIENTO EN VIVO</p>
              <div class="relative inline-block">
                <div class="text-9xl font-black text-white">60</div>
                <div class="absolute -bottom-2 right-0 text-2xl font-bold text-red-700">FPS</div>
              </div>
            </div>
            <div class="space-y-3">
              <div class="flex items-center justify-between text-sm">
                <span class="text-gray-400">Latencia:</span>
                <span class="font-bold text-green-400">12 ms</span>
              </div>
              <div class="flex items-center justify-between text-sm">
                <span class="text-gray-400">Ancho de banda:</span>
                <span class="font-bold text-blue-400">87 KB/s</span>
              </div>
              <div class="flex items-center justify-between text-sm">
                <span class="text-gray-400">Resolucion:</span>
                <span class="font-bold text-purple-400">1920x1080</span>
              </div>
              <div class="flex items-center justify-between text-sm">
                <span class="text-gray-400">Codec:</span>
                <span class="font-bold text-orange-400">DeskRT v2.1</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Seguridad de Grado Bancario -->
    <section class="py-24 bg-gray-50">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-[#0f172a] mb-4">Seguridad de Grado Bancario</h2>
          <p class="text-lg text-[#64748b] max-w-2xl mx-auto">
            Proteja sus activos digitales con tecnología de cifrado estandarizada. Su seguridad es nuestra prioridad.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-white border-2 border-gray-200 rounded-xl p-8 hover:shadow-xl transition-all duration-300 cursor-pointer">
            <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-[#0f172a] mb-3">Cifrado TLS 1.2</h3>
            <p class="text-[#64748b] text-sm leading-relaxed">
              Utilizamos la misma tecnología que la banca online para proteger la conexion. Nadie puede interceptar su sesion.
            </p>
          </div>

          <div class="bg-white border-2 border-gray-200 rounded-xl p-8 hover:shadow-xl transition-all duration-300 cursor-pointer">
            <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-[#0f172a] mb-3">Intercambio RSA 2048</h3>
            <p class="text-[#64748b] text-sm leading-relaxed">
              Cifrado asimetrico para verificar cada conexion. Perfect Forward Secrecy garantiza que sesiones pasadas sean seguras.
            </p>
          </div>

          <div class="bg-white border-2 border-gray-200 rounded-xl p-8 hover:shadow-xl transition-all duration-300 cursor-pointer">
            <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-[#0f172a] mb-3">Arquitectura Erlang</h3>
            <p class="text-[#64748b] text-sm leading-relaxed">
              Backend construido en Erlang/OTP, el mismo lenguaje de telecomunicaciones críticas. 99.999% uptime garantizado.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Diseñado para Profesionales TI -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-[#0f172a] mb-4">Diseñado para Profesionales TI</h2>
          <p class="text-lg text-[#64748b] max-w-2xl mx-auto">
            Herramientas avanzadas que simplifican la administración masiva de endpoints corporativos
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          <div class="text-center">
            <div class="w-16 h-16 bg-blue-100 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-[#0f172a] mb-2">Transferencia de Archivos</h3>
            <p class="text-sm text-[#64748b]">Arrastre archivos de hasta 5 GB entre equipos como si fueran carpetas locales. Clipboard bidireccional.</p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-green-100 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-[#0f172a] mb-2">Grabacion Remota</h3>
            <p class="text-sm text-[#64748b]">Registre sesiones completas para auditorías de compliance o capacitación. Formato MP4 estandar.</p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-purple-100 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-[#0f172a] mb-2">Libreta de Direcciones</h3>
            <p class="text-sm text-[#64748b]">Organice 10,000+ endpoints con grupos, etiquetas y búsqueda inteligente. Sincronizacion multi-usuario.</p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-red-100 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-red-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-[#0f172a] mb-2">Acceso no Supervisado</h3>
            <p class="text-sm text-[#64748b]">Configure contraseñas permanentes para servidores/kioscos. Reinicio remoto y reconexion automatica.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Multi-Plataforma -->
    <section class="py-24 bg-gradient-to-br from-gray-50 to-white">
      <div class="max-w-6xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold text-[#0f172a] mb-4">Funciona en Todo Sistema Operativo</h2>
          <p class="text-lg text-[#64748b]">Un solo ID de AnyDesk para controlar Windows, Mac, Linux, Android, iOS, Raspberry Pi y FreeBSD</p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-5 gap-6">
          <div class="bg-white border-2 border-gray-200 rounded-xl p-6 text-center hover:border-blue-500 transition cursor-pointer">
            <div class="w-16 h-16 bg-blue-100 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-10 h-10 text-blue-600" viewBox="0 0 24 24" fill="currentColor">
                <path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/>
              </svg>
            </div>
            <h4 class="font-bold text-sm text-[#0f172a]">Windows</h4>
            <p class="text-xs text-gray-500 mt-1">7, 10, 11, Server</p>
          </div>
          <div class="bg-white border-2 border-gray-200 rounded-xl p-6 text-center hover:border-gray-700 transition cursor-pointer">
            <div class="w-16 h-16 bg-gray-100 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-10 h-10 text-gray-700" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
            </div>
            <h4 class="font-bold text-sm text-[#0f172a]">macOS</h4>
            <p class="text-xs text-gray-500 mt-1">10.13+</p>
          </div>
          <div class="bg-white border-2 border-gray-200 rounded-xl p-6 text-center hover:border-yellow-500 transition">
            <div class="w-16 h-16 bg-yellow-100 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-10 h-10 text-yellow-600" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.835-.41 1.684-.287 2.489.845 5.331 6.925 6.881 10.95 4.526.851-.498 1.421-1.352 1.678-2.355.249-.977.36-2.076.36-3.331 0-2.59-.38-4.537-.933-6.14-.553-1.604-1.38-2.85-2.127-3.757C13.84.984 13.059.365 12.504 0zm-.529 3.871c1.049 0 1.898.849 1.898 1.897 0 1.05-.849 1.899-1.898 1.899-1.05 0-1.898-.849-1.898-1.899 0-1.048.848-1.897 1.898-1.897z"/>
              </svg>
            </div>
            <h4 class="font-bold text-sm text-[#0f172a]">Linux</h4>
            <p class="text-xs text-gray-500 mt-1">Ubuntu, Debian, RPM</p>
          </div>
          <div class="bg-white border-2 border-gray-200 rounded-xl p-6 text-center hover:border-green-500 transition cursor-pointer">
            <div class="w-16 h-16 bg-green-100 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-10 h-10 text-green-600" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.523 15.341c-.759 0-1.373.616-1.373 1.373s.615 1.373 1.373 1.373c.758 0 1.373-.615 1.373-1.373s-.616-1.373-1.373-1.373z"/>
                <path d="M6.477 15.341c-.758 0-1.373.616-1.373 1.373s.616 1.373 1.373 1.373c.759 0 1.373-.615 1.373-1.373s-.615-1.373-1.373-1.373z"/>
                <path d="M16.423 8.134l1.217-2.109c.084-.146.029-.334-.117-.418-.146-.083-.334-.029-.418.117l-1.234 2.137C14.698 7.363 13.392 7 12 7c-1.392 0-2.698.363-3.871.861L6.895 5.724c-.084-.146-.272-.2-.418-.117-.146.084-.2.272-.117.418l1.217 2.109C5.16 9.505 3.5 12.246 3.5 15.341h17c0-3.095-1.66-5.836-4.077-7.207z"/>
              </svg>
            </div>
            <h4 class="font-bold text-sm text-[#0f172a]">Android</h4>
            <p class="text-xs text-gray-500 mt-1">5.0+</p>
          </div>
          <div class="bg-white border-2 border-gray-200 rounded-xl p-6 text-center hover:border-gray-800 transition cursor-pointer">
            <div class="w-16 h-16 bg-gray-800 rounded-xl flex items-center justify-center mx-auto mb-4">
