---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';
import WhatsAppButton from '@components/WhatsAppButton.astro';
import { seoData } from '@data/seo';

const seo = seoData['soti-mdm'];
---

<BaseLayout seo={seo}>
  <Navbar />

  <div class="bg-white min-h-screen w-full font-['Instrument_Sans',sans-serif]">

    <!-- Hero Section -->
    <section class="relative bg-gradient-to-br from-[#111827] via-[#1e293b] to-[#0f172a] py-24 lg:py-32 overflow-hidden">
      <!-- Grid Background -->
      <div class="absolute inset-0 opacity-10">
        <div
          class="absolute w-full h-full"
          style="background-image: linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 50px 50px;"
        ></div>
      </div>

      <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">

        <!-- Badge -->
        <div class="flex justify-center mb-6">
          <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 px-4 py-2 rounded-full">
            <svg class="w-4 h-4 text-red-700" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span class="text-xs font-bold text-white uppercase tracking-wider">
              LIDER MUNDIAL EN MDM
            </span>
          </div>
        </div>

        <!-- Main Heading -->
        <div class="text-center mb-12 max-w-5xl mx-auto">
          <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.1] tracking-tight mb-6">
            <span class="block text-white">Gestión de movilidad para</span>
            <span class="block text-red-700">el borde de la red.</span>
          </h1>
          <p class="text-xl text-gray-300 leading-relaxed max-w-3xl mx-auto">
            SOTI MobiControl es la plataforma de <strong class="text-white">Gestión de Dispositivos Móviles (MDM)</strong> más
            completa del mercado. Controle tablets, smartphones, impresoras industriales, kioscos y wearables desde una consola unificada.
          </p>
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
          <a
            href="/contacto"
            class="bg-gradient-to-r from-red-600 to-red-700 text-white font-semibold px-8 py-4 rounded-full hover:from-red-700 hover:to-red-800 transition shadow-lg inline-flex items-center justify-center gap-2"
          >
            Solicitar Demo Gratuita
          </a>
          <a
            href="#caracteristicas"
            class="bg-white/10 backdrop-blur-sm border border-white/20 text-white font-semibold px-8 py-4 rounded-full hover:bg-white/20 transition inline-flex items-center justify-center gap-2"
          >
            Ver Características
          </a>
        </div>

        <!-- Stats Grid -->
        <div class="max-w-5xl mx-auto">
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
            <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-xl p-6 text-center hover:bg-white/15 transition">
              <div class="text-4xl font-bold text-red-700 mb-2">15M+</div>
              <p class="text-sm text-gray-300">Dispositivos gestionados</p>
            </div>
            <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-xl p-6 text-center hover:bg-white/15 transition">
              <div class="text-4xl font-bold text-blue-400 mb-2">170+</div>
              <p class="text-sm text-gray-300">Países activos</p>
            </div>
            <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-xl p-6 text-center hover:bg-white/15 transition">
              <div class="text-4xl font-bold text-green-400 mb-2">24/7</div>
              <p class="text-sm text-gray-300">Soporte técnico global</p>
            </div>
            <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-xl p-6 text-center hover:bg-white/15 transition">
              <div class="text-4xl font-bold text-purple-400 mb-2">30+</div>
              <p class="text-sm text-gray-300">Años de experiencia</p>
            </div>
          </div>
        </div>

        <!-- Hero Image -->
        <div class="hidden lg:flex items-center justify-center mt-12">
          <img src="/assets/icono-dispositivo-endpoint-security.webp" alt="Gestión de dispositivos móviles empresariales con SOTI MobiControl" class="w-full max-w-sm rounded-2xl shadow-xl" width="384" height="384" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- Por que SOTI? -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div>
            <span class="inline-block bg-red-50 text-red-700 text-xs font-bold px-3 py-1 rounded-full mb-4 uppercase tracking-wider">
              La Diferencia SOTI
            </span>
            <h2 class="text-4xl font-bold text-[#0f172a] mb-6 leading-tight">
              Más allá del MDM tradicional: Enterprise Mobility Management Total
            </h2>
            <p class="text-lg text-[#64748b] mb-6 leading-relaxed">
              Mientras otros MDM se limitan a políticas básicas, <strong class="text-[#0f172a]">SOTI MobiControl</strong> ofrece
              control granular sobre hardware específico, APIs propietarias y funcionalidades que ningún competidor puede igualar.
            </p>

            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 bg-red-700 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div>
                  <h4 class="font-bold text-lg text-[#0f172a] mb-1">Control Total de Hardware Industrial</h4>
                  <p class="text-sm text-[#475569]">
                    Gestione <strong>impresoras Zebra, escáneres Honeywell, terminales Panasonic</strong> con APIs nativas.
                    Configure códigos de barras, reemplace baterías remotamente y actualice firmware sin tocar el dispositivo.
                  </p>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <div class="w-6 h-6 bg-red-700 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div>
                  <h4 class="font-bold text-lg text-[#0f172a] mb-1">Modo Kiosco con HTML5 Personalizado</h4>
                  <p class="text-sm text-[#475569]">
                    Cree interfaces de usuario completamente personalizadas. Oculte la barra de notificaciones Android,
                    deshabilite botones físicos y permita solo sus aplicaciones críticas de negocio.
                  </p>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <div class="w-6 h-6 bg-red-700 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div>
                  <h4 class="font-bold text-lg text-[#0f172a] mb-1">SOTI XTreme: Rugged Devices</h4>
                  <p class="text-sm text-[#475569]">
                    Soporte especializado para dispositivos ultra resistentes (Zebra TC21, Honeywell CT40, Panasonic Toughbook).
                    Monitoreo de temperatura, caídas, salud de batería y ciclos de carga.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Right - Device Visual -->
          <div class="relative">
            <div class="bg-gradient-to-br from-[#111827] to-[#1e293b] rounded-2xl p-8 lg:p-12 border-2 border-gray-700">
              <div class="space-y-6">
                <div class="flex items-center justify-between text-sm">
                  <span class="text-gray-400">Dispositivos Online:</span>
                  <span class="font-bold text-green-400">14,847 / 15,000</span>
                </div>
                <div class="flex items-center justify-between text-sm">
                  <span class="text-gray-400">Batería promedio:</span>
                  <span class="font-bold text-blue-400">78%</span>
                </div>
                <div class="flex items-center justify-between text-sm">
                  <span class="text-gray-400">Alertas activas:</span>
                  <span class="font-bold text-orange-400">3 críticas</span>
                </div>
                <div class="flex items-center justify-between text-sm">
                  <span class="text-gray-400">Aplicaciones gestionadas:</span>
                  <span class="font-bold text-purple-400">247</span>
                </div>
                <div class="flex items-center justify-between text-sm">
                  <span class="text-gray-400">Políticas activas:</span>
                  <span class="font-bold text-cyan-400">89</span>
                </div>

                <div class="pt-6 border-t border-gray-700">
                  <p class="text-xs text-gray-500 uppercase tracking-wider mb-3">Distribución por OS</p>
                  <div class="space-y-3">
                    <div>
                      <div class="flex justify-between text-xs mb-1">
                        <span class="text-gray-400">Android</span>
                        <span class="text-white font-bold">67%</span>
                      </div>
                      <div class="w-full bg-gray-800 rounded-full h-2">
                        <div class="bg-green-500 h-2 rounded-full" style="width: 67%;"></div>
                      </div>
                    </div>
                    <div>
                      <div class="flex justify-between text-xs mb-1">
                        <span class="text-gray-400">iOS</span>
                        <span class="text-white font-bold">23%</span>
                      </div>
                      <div class="w-full bg-gray-800 rounded-full h-2">
                        <div class="bg-blue-500 h-2 rounded-full" style="width: 23%;"></div>
                      </div>
                    </div>
                    <div>
                      <div class="flex justify-between text-xs mb-1">
                        <span class="text-gray-400">Windows</span>
                        <span class="text-white font-bold">10%</span>
                      </div>
                      <div class="w-full bg-gray-800 rounded-full h-2">
                        <div class="bg-purple-500 h-2 rounded-full" style="width: 10%;"></div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Floating badge -->
            <div class="absolute -top-4 -right-4 bg-red-700 text-white px-6 py-3 rounded-xl shadow-xl">
              <p class="text-xs font-bold uppercase">Dashboard en Vivo</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Gestion Profunda del Dispositivo -->
    <section id="caracteristicas" class="py-24 bg-gray-50">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-[#0f172a] mb-4">Gestión Profunda del Dispositivo</h2>
          <p class="text-lg text-[#64748b] max-w-2xl mx-auto">
            MobiControl va más allá de las APIs estándar. Ofrecemos control granular sobre hardware específico y funcionalidades avanzadas.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-[#f8fafc] border-2 border-gray-200 rounded-xl p-8 hover:shadow-xl transition-all duration-300 cursor-pointer">
            <div class="w-12 h-12 bg-white border border-gray-200 rounded-lg flex items-center justify-center mb-6 shadow-sm">
              <svg class="w-6 h-6 text-[#0f172a]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-[#0f172a] mb-3">Remote Control (Blaze)</h3>
            <p class="text-[#64748b] text-sm leading-relaxed">
              Acceda remotamente a dispositivos en campo con la velocidad de streaming más rápida del mercado.
              Diagnostique problemas visualizando la pantalla, accediendo al sistema de archivos y ejecutando scripts en vivo.
            </p>
          </div>

          <div class="bg-[#f8fafc] border-2 border-gray-200 rounded-xl p-8 hover:shadow-xl transition-all duration-300 cursor-pointer">
            <div class="w-12 h-12 bg-white border border-gray-200 rounded-lg flex items-center justify-center mb-6 shadow-sm">
              <svg class="w-6 h-6 text-[#0f172a]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-[#0f172a] mb-3">Kiosk Mode & Lockdown</h3>
            <p class="text-[#64748b] text-sm leading-relaxed">
              Cree interfaces de usuario personalizadas con HTML5. Restrinja el acceso al sistema operativo,
              oculte la barra de notificaciones y permita solo aplicaciones de negocio críticas.
            </p>
          </div>

          <div class="bg-[#f8fafc] border-2 border-gray-200 rounded-xl p-8 hover:shadow-xl transition-all duration-300 cursor-pointer">
            <div class="w-12 h-12 bg-white border border-gray-200 rounded-lg flex items-center justify-center mb-6 shadow-sm">
              <svg class="w-6 h-6 text-[#0f172a]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-[#0f172a] mb-3">Gestión de Contenido</h3>
            <p class="text-[#64748b] text-sm leading-relaxed">
              Distribuya documentos, PDFs, videos y archivos de capacitación a 10,000+ dispositivos simultáneamente.
              Sincronización delta para minimizar ancho de banda.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Control Remoto Android -->
    <section class="py-24 bg-[#0f172a] text-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <!-- Left - Code Example -->
          <div>
            <div class="bg-[#1e293b] border border-gray-700 rounded-xl overflow-hidden">
              <div class="bg-[#111827] px-6 py-3 border-b border-gray-700 flex items-center gap-2">
                <div class="w-3 h-3 bg-red-500 rounded-full"></div>
                <div class="w-3 h-3 bg-yellow-500 rounded-full"></div>
                <div class="w-3 h-3 bg-green-500 rounded-full"></div>
                <span class="ml-4 text-xs text-gray-400 font-mono">MobiControl API</span>
              </div>
              <div class="p-6 font-mono text-sm overflow-x-auto">
                <pre class="text-gray-300">// Reiniciar dispositivo remotamente
await device.reboot();

// Configurar modo kiosco
await device.setKioskMode({'{'}
  app: "com.empresa.app",
  hideNavBar: true,
  disableCamera: true
{'}'});

// Geolocalizacion en tiempo real
const location = await device.getLocation();
console.log(location.lat, location.lng);

// Configurar impresora Zebra
await printer.setResolution(300);
await printer.printLabel(zpl_code);</pre>
              </div>
            </div>
          </div>

          <!-- Right Content -->
          <div>
            <span class="inline-block bg-blue-500/20 text-blue-300 text-xs font-bold px-3 py-1 rounded-full mb-4 uppercase tracking-wider">
              Automatización Completa
            </span>
            <h2 class="text-4xl font-bold mb-6 leading-tight">
              Desarrolle con nuestra API REST completa.
            </h2>
            <p class="text-lg text-gray-300 mb-6 leading-relaxed">
              Integre SOTI MobiControl con sus sistemas ERP, WMS, CRM o ticketing. API RESTful con documentación completa
              y SDKs oficiales para Java, .NET, Python y Node.js.
            </p>

            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-green-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <span class="text-white font-semibold">Webhooks en tiempo real</span>
                  <p class="text-sm text-gray-400">Reciba notificaciones push cuando cambie el estado del dispositivo</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-green-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <span class="text-white font-semibold">OAuth 2.0 + SAML SSO</span>
                  <p class="text-sm text-gray-400">Autenticación empresarial con Azure AD, Okta, Google Workspace</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-green-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <span class="text-white font-semibold">Rate limit generoso: 10,000 req/hora</span>
                  <p class="text-sm text-gray-400">Escale sin preocupaciones con infraestructura cloud global</p>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Seguridad de Nivel Militar -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold text-[#0f172a] mb-4">Seguridad de Nivel Militar</h2>
          <p class="text-lg text-[#64748b] max-w-2xl mx-auto">
            SOTI MobiControl es la plataforma elegida por gobiernos, fuerzas armadas y organizaciones de infraestructura crítica
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          <div class="text-center">
            <div class="w-16 h-16 bg-blue-100 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-[#0f172a] mb-2">Cifrado AES-256</h3>
            <p class="text-sm text-[#64748b]">Datos en tránsito y reposo cifrados con estándar militar. Certificación FIPS 140-2 nivel 2.</p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-green-100 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-[#0f172a] mb-2">Zero-Trust Architecture</h3>
            <p class="text-sm text-[#64748b]">Verificación continua de identidad. MFA obligatorio, certificados X.509, biometría.</p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-purple-100 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-[#0f172a] mb-2">Remote Wipe Instantáneo</h3>
            <p class="text-sm text-[#64748b]">Borre datos corporativos en &lt;3 segundos si detecta jailbreak, rooting o pérdida del dispositivo.</p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-red-100 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-red-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
