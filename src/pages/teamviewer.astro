---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';
import WhatsAppButton from '@components/WhatsAppButton.astro';
import { seoData } from '@data/seo';

const seo = seoData.teamviewer;
---

<BaseLayout seo={seo}>
  <Navbar />

  <div class="bg-white min-h-screen w-full font-['Instrument_Sans',sans-serif]">

    <!-- Hero Section -->
    <section class="relative py-20 sm:py-28 lg:py-36 bg-gradient-to-br from-[#f8fafc] to-white overflow-hidden">
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-gradient-to-br from-[#dbeafe] to-transparent rounded-full blur-3xl opacity-30"></div>

      <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <!-- Left Content -->
          <div>
            <div class="inline-flex items-center gap-2 bg-[#eff6ff] border border-[#dbeafe] px-4 py-2 rounded-full mb-8">
              <svg class="w-4 h-4 text-[#2563eb]" fill="currentColor" viewBox="0 0 20 20">
                <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z"/>
              </svg>
              <span class="text-[#2563eb] text-xs font-semibold tracking-wider uppercase">
                Control Remoto Empresarial
              </span>
            </div>

            <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.1] tracking-tight mb-6">
              <span class="block text-[#0f172a]">TeamViewer: El</span>
              <span class="block text-[#0f172a]">Estándar Global de</span>
              <span class="block bg-gradient-to-r from-[#2563eb] to-[#1d4ed8] bg-clip-text text-transparent" style="-webkit-text-fill-color: transparent;">
                Control Remoto
              </span>
              <span class="block text-[#0f172a]">Seguro para Empresas</span>
            </h1>

            <p class="text-lg text-[#64748b] leading-relaxed mb-10">
              Conéctese a cualquier dispositivo, en cualquier lugar. Con más de 2.5 mil millones de
              dispositivos conectados, TeamViewer es la solución líder en acceso remoto, soporte y
              colaboración para empresas de todos los tamaños.
            </p>

            <div class="flex flex-col sm:flex-row gap-4 mb-12">
              <a
                href="/contacto"
                class="bg-gradient-to-r from-red-600 to-red-700 text-white font-semibold px-8 py-4 rounded-full hover:from-red-700 hover:to-red-800 transition shadow-lg inline-flex items-center justify-center gap-2"
              >
                Solicitar Cotización
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
              <a
                href="/contacto"
                class="bg-white border-2 border-gray-200 text-gray-800 font-semibold px-8 py-4 rounded-full hover:bg-gray-50 transition inline-flex items-center justify-center gap-2"
              >
                Hablar con Asesor
              </a>
            </div>

            <div class="inline-flex items-center gap-3 text-sm text-[#64748b]">
              <svg class="w-5 h-5 text-[#22c55e]" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="font-semibold">Certificado ISO 27001 - Cumplimiento GDPR - SOC2 Type II</span>
            </div>
          </div>

          <!-- Right - Feature Card -->
          <div class="relative">
            <div class="bg-white border border-[#e5e7eb] rounded-2xl p-8 shadow-2xl">
              <div class="mb-6">
                <div class="inline-flex items-center gap-2 bg-[#f1f5f9] px-3 py-1.5 rounded-full mb-4">
                  <div class="w-2 h-2 bg-[#22c55e] rounded-full animate-pulse"></div>
                  <span class="text-xs font-semibold text-[#475569] uppercase tracking-wider">En vivo ahora</span>
                </div>
                <h3 class="text-2xl font-bold text-[#0f172a] mb-2">Conexión Instantánea</h3>
                <p class="text-sm text-[#64748b]">Acceso remoto en segundos desde cualquier dispositivo</p>
              </div>

              <div class="bg-gradient-to-br from-[#f8fafc] to-[#f1f5f9] rounded-xl p-6 mb-4">
                <div class="flex items-center justify-between mb-4">
                  <div class="flex items-center gap-2">
                    <div class="w-3 h-3 bg-[#ef4444] rounded-full"></div>
                    <div class="w-3 h-3 bg-[#f59e0b] rounded-full"></div>
                    <div class="w-3 h-3 bg-[#22c55e] rounded-full"></div>
                  </div>
                  <div class="text-xs text-[#94a3b8] font-mono">ID: 987 654 321</div>
                </div>

                <div class="bg-white rounded-lg p-4 mb-3">
                  <div class="flex items-center gap-3 mb-3">
                    <div class="w-10 h-10 bg-[#dbeafe] rounded-lg flex items-center justify-center">
                      <svg class="w-5 h-5 text-[#2563eb]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                      </svg>
                    </div>
                    <div>
                      <div class="text-sm font-semibold text-[#0f172a]">Servidor Principal</div>
                      <div class="text-xs text-[#64748b]">Windows Server 2022</div>
                    </div>
                  </div>
                  <div class="h-1.5 bg-[#e5e7eb] rounded-full overflow-hidden">
                    <div class="h-full bg-[#2563eb] rounded-full" style="width: 78%;"></div>
                  </div>
                  <div class="text-xs text-[#64748b] mt-2">Transferencia: 45 MB/s</div>
                </div>

                <div class="grid grid-cols-3 gap-2">
                  <div class="bg-white rounded-lg px-3 py-2 text-center">
                    <div class="text-xs font-semibold text-[#475569]">Control Total</div>
                  </div>
                  <div class="bg-white rounded-lg px-3 py-2 text-center">
                    <div class="text-xs font-semibold text-[#475569]">Transferir</div>
                  </div>
                  <div class="bg-white rounded-lg px-3 py-2 text-center">
                    <div class="text-xs font-semibold text-[#475569]">Chat</div>
                  </div>
                </div>
              </div>

              <div class="flex items-center gap-2 text-xs text-[#64748b]">
                <svg class="w-4 h-4 text-[#22c55e]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
                </svg>
                <span>Conexión cifrada AES 256-bit end-to-end</span>
              </div>
            </div>

            <!-- Hero Image -->
            <div class="mt-6 flex items-center justify-center">
              <img src="/assets/emblema-seguridad-cloud.webp" alt="TeamViewer control remoto empresarial seguro con cifrado" class="w-full max-w-xs rounded-2xl shadow-xl" width="320" height="320" loading="lazy" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust Logos -->
    <section class="py-12 bg-white border-y border-[#f3f4f6]">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <p class="text-center text-[#9ca3af] text-xs font-semibold uppercase tracking-wider mb-8">
          Confianza de 90% de las empresas Fortune 500
        </p>
        <div class="flex flex-wrap items-center justify-center gap-12 opacity-60">
          <div class="text-[#475569] text-xl font-bold tracking-tight">LogisticsCo</div>
          <div class="text-[#475569] text-xl font-bold tracking-tight">HealthCare+</div>
          <div class="text-[#475569] text-xl font-bold tracking-tight">TechGiant</div>
          <div class="text-[#475569] text-xl font-bold tracking-tight">FinanceHub</div>
        </div>
      </div>
    </section>

    <!-- Infrastructure Section -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-[#0f172a] mb-4">
            Infraestructura diseñada para la confiabilidad de negocio
          </h2>
          <p class="text-lg text-[#64748b] max-w-3xl mx-auto">
            Acceso remoto empresarial con redundancia global, cumplimiento regulatorio y soporte 24/7
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="w-16 h-16 bg-[#eff6ff] rounded-2xl flex items-center justify-center mx-auto mb-6">
              <svg class="w-8 h-8 text-[#2563eb]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-[#0f172a] mb-3">Control sin Restricciones 24/7</h3>
            <p class="text-sm text-[#64748b] leading-relaxed">
              Acceda a servidores, estaciones de trabajo y dispositivos IoT en cualquier momento.
              Configuración permanente sin necesidad de aprobación del usuario remoto.
            </p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-[#eff6ff] rounded-2xl flex items-center justify-center mx-auto mb-6">
              <svg class="w-8 h-8 text-[#2563eb]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-[#0f172a] mb-3">Seguridad de Grado Militar</h3>
            <p class="text-sm text-[#64748b] leading-relaxed">
              Cifrado AES 256-bit, autenticación de dos factores, listas blancas/negras,
              y registro completo de todas las sesiones para auditorías.
            </p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-[#eff6ff] rounded-2xl flex items-center justify-center mx-auto mb-6">
              <svg class="w-8 h-8 text-[#2563eb]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-[#0f172a] mb-3">Escale y Facture Flexible</h3>
            <p class="text-sm text-[#64748b] leading-relaxed">
              Desde equipos pequeños hasta flotas de miles de dispositivos. Licencias concurrentes
              o nombradas, facturación mensual o anual.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Simple Remote Access Section -->
    <section class="py-24 bg-[#f8fafc]">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <p class="text-[#2563eb] text-sm font-semibold uppercase tracking-wider mb-4">
              Más que simple acceso remoto,
            </p>
            <h2 class="text-4xl font-bold text-[#0f172a] mb-6">
              es <span class="text-[#2563eb]">estabilidad corporativa.</span>
            </h2>

            <div class="space-y-4 mb-8">
              <div class="flex items-start gap-4">
                <div class="w-6 h-6 bg-[#2563eb] rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-[#0f172a] mb-1">Soporte remoto instantáneo para empleados</h3>
                  <p class="text-sm text-[#64748b]">
                    Resuelva tickets en minutos, no horas. Vea la pantalla del usuario, tome control y solucione
                    problemas de software, configuración o hardware sin desplazamientos.
                  </p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-6 h-6 bg-[#2563eb] rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-[#0f172a] mb-1">Gestión centralizada de dispositivos remotos</h3>
                  <p class="text-sm text-[#64748b]">
                    Administre servidores, workstations, POS y cajeros desde una consola web unificada.
                    Depliegue actualizaciones, ejecute scripts y monitoree estados en tiempo real.
                  </p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-6 h-6 bg-[#2563eb] rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-[#0f172a] mb-1">Integraciones con PSA/RMM</h3>
                  <p class="text-sm text-[#64748b]">
                    Conectese con ConnectWise, Autotask, Datto RMM, N-able. Ticketing automático y
                    facturación por tiempo de sesión para MSPs.
                  </p>
                </div>
              </div>
            </div>

            <div class="bg-white border border-[#e5e7eb] rounded-xl p-6">
              <div class="flex items-start gap-4">
                <svg class="w-6 h-6 text-[#f59e0b] flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <h4 class="font-semibold text-[#0f172a] mb-2">Notas para MSPs y Distribuidores IT</h4>
                  <p class="text-sm text-[#64748b]">
                    Disponemos de licencias por volumen con descuentos escalonados, soporte técnico nivel 3
                    incluido y acceso a portal de partners. Contacte para pricing mayorista.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Stats Grid -->
          <div class="grid grid-cols-2 gap-6">
            <div class="bg-white border border-[#e5e7eb] rounded-xl p-6">
              <div class="text-4xl font-bold text-[#2563eb] mb-2">2.5B+</div>
              <div class="text-sm text-[#64748b]">Dispositivos Conectados</div>
            </div>
            <div class="bg-white border border-[#e5e7eb] rounded-xl p-6">
              <div class="text-4xl font-bold text-[#2563eb] mb-2">600k+</div>
              <div class="text-sm text-[#64748b]">Empresas Clientes</div>
            </div>
            <div class="bg-white border border-[#e5e7eb] rounded-xl p-6">
              <div class="text-4xl font-bold text-[#2563eb] mb-2">45M</div>
              <div class="text-sm text-[#64748b]">Sesiones Diarias</div>
            </div>
            <div class="bg-white border border-[#e5e7eb] rounded-xl p-6">
              <div class="text-4xl font-bold text-[#2563eb] mb-2">99.99%</div>
              <div class="text-sm text-[#64748b]">Uptime SLA</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Dark Section - Remote Maintenance -->
    <section class="py-24 bg-[#0f172a] text-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-4xl font-bold mb-6">
              Resolución crítica de incidencias
            </h2>
            <p class="text-lg text-[#94a3b8] mb-8">
              Cuando los servidores caen a las 3 AM, TeamViewer esta listo. Acceso out-of-band
              via BIOS, recuperación de sistemas sin OS funcional, y control de infraestructura IoT industrial.
            </p>

            <div class="space-y-4">
              <div class="flex items-start gap-4 bg-[#1e293b] rounded-lg p-4">
                <div class="text-3xl">&#128295;</div>
                <div>
                  <h3 class="font-bold text-white mb-1">Wake-on-LAN</h3>
                  <p class="text-sm text-[#94a3b8]">Encienda equipos apagados remotamente</p>
                </div>
              </div>
              <div class="flex items-start gap-4 bg-[#1e293b] rounded-lg p-4">
                <div class="text-3xl">&#128241;</div>
                <div>
                  <h3 class="font-bold text-white mb-1">Control multi-plataforma</h3>
                  <p class="text-sm text-[#94a3b8]">Windows, macOS, Linux, Android, iOS</p>
                </div>
              </div>
              <div class="flex items-start gap-4 bg-[#1e293b] rounded-lg p-4">
                <div class="text-3xl">&#127919;</div>
                <div>
                  <h3 class="font-bold text-white mb-1">Session Recording</h3>
                  <p class="text-sm text-[#94a3b8]">Grabe sesiones para compliance y training</p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-gradient-to-br from-[#1e293b] to-[#0f172a] rounded-2xl p-8 border border-[#334155]">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-12 h-12 bg-[#2563eb] rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-bold">Caso de Uso</h3>
                <p class="text-sm text-[#94a3b8]">Mantenimiento Crítico</p>
              </div>
            </div>

            <p class="text-[#cbd5e1] mb-6">
              "Nuestro NOC en Bogota administra 450+ servidores distribuidos en 8 países. TeamViewer
              nos permite responder a incidentes en menos de 2 minutos, realizar mantenimientos nocturnos
              sin desplazamientos y mantener un SLA de 99.95%."
            </p>

            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-[#334155] rounded-full"></div>
              <div>
                <div class="font-semibold text-white">Carlos Mendez</div>
                <div class="text-sm text-[#94a3b8]">Director de IT, Empresa Logistica</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Casos de Uso por Industria -->
    <section class="py-16 sm:py-20 lg:py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold mb-4 text-gray-900">
            Casos de Uso por Industria
          </h2>
          <p class="text-gray-600 max-w-2xl mx-auto">
            TeamViewer se adapta a los requerimientos específicos de cada sector, desde soporte TI
            hasta automatización industrial y telemedicina.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:shadow-lg transition-all duration-300 cursor-pointer">
            <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="font-bold text-gray-900 text-lg mb-3">Soporte TI Remoto</h3>
            <p class="text-sm text-gray-600 leading-relaxed">
              Equipos de helpdesk resuelven tickets sin desplazamientos. Acceso instantáneo a
              cualquier endpoint de la organización, transferencia de archivos y sesiones grabadas
              para auditoría y entrenamiento.
            </p>
          </div>

          <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:shadow-lg transition-all duration-300 cursor-pointer">
