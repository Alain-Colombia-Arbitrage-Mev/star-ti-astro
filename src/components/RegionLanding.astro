---
import type { RegionData } from '@data/regions';
import { serviceLinks } from '@data/regions';
import { pilares } from '@data/pilares';

interface Props {
  region: RegionData;
}

const { region } = Astro.props;
const isEnglish = region.countryCode === 'US';

const pilarColors: Record<string, { bg: string; text: string; border: string }> = {
  red: { bg: 'bg-red-50', text: 'text-red-800', border: 'border-red-200' },
  blue: { bg: 'bg-blue-50', text: 'text-blue-800', border: 'border-blue-200' },
  emerald: { bg: 'bg-emerald-50', text: 'text-emerald-800', border: 'border-emerald-200' },
};
---

<!-- Hero Section -->
<section class="relative overflow-hidden pt-16 sm:pt-24 lg:pt-32 pb-20 sm:pb-32 bg-gradient-to-br from-gray-950 via-gray-900 to-black">
  <div class="absolute inset-0 pointer-events-none opacity-10">
    <div class="absolute inset-0" style="background-image: linear-gradient(to right, #6b7280 1px, transparent 1px), linear-gradient(to bottom, #6b7280 1px, transparent 1px); background-size: 60px 60px;"></div>
  </div>
  <div class="absolute top-20 left-1/4 w-[400px] h-[400px] bg-red-600/15 rounded-full blur-3xl"></div>
  <div class="absolute bottom-20 right-1/4 w-[400px] h-[400px] bg-blue-600/10 rounded-full blur-3xl"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <div class="inline-flex items-center gap-2 backdrop-blur-md bg-white/10 border border-white/20 rounded-full px-4 py-2 mb-6">
        <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
        <span class="text-sm font-medium text-white uppercase tracking-wide">
          {isEnglish ? 'Active Protection' : 'Protección Activa'} - {region.city}
        </span>
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-6 text-white">
        {region.heroTitle}
      </h1>
      <p class="text-lg sm:text-xl text-gray-300 mb-8 leading-relaxed">
        {region.heroSubtitle}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 mb-12">
        <a href={`/${region.slug ? region.slug + '/contacto' : 'contacto'}`} class="bg-gradient-to-r from-red-500 to-red-600 text-white font-semibold px-8 py-4 rounded-full hover:from-red-600 hover:to-red-700 transition shadow-lg text-center">
          {isEnglish ? 'Request a Consultation' : 'Solicitar Consultoría'}
        </a>
        <a href={`tel:${region.phone}`} class="backdrop-blur-xl bg-white/10 border border-white/20 text-white font-semibold px-8 py-4 rounded-full hover:bg-white/20 transition text-center">
          {region.phoneDisplay}
        </a>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {region.stats.map((stat) => (
          <div class="backdrop-blur-xl bg-white/10 border border-white/20 rounded-2xl px-4 py-4 text-center">
            <div class="text-2xl sm:text-3xl font-bold text-white mb-1">{stat.value}</div>
            <div class="text-xs sm:text-sm text-gray-400">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- 3 Pillars Section -->
<section class="py-16 sm:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">
        {isEnglish ? `Our 3 Pillars of Digital Resilience` : `Los 3 Pilares de Resiliencia Digital`}
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        {isEnglish
          ? `Three converging pillars providing complete cybersecurity coverage for businesses in ${region.country}.`
          : `Tres pilares convergentes que brindan cobertura completa de ciberseguridad para empresas en ${region.country}. Cada pilar incluye consultoría especializada, implementación y soporte continuo.`}
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      {pilares.map((pilar) => {
        const colors = pilarColors[pilar.color];
        return (
          <div class={`bg-white border-2 ${colors.border} rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-300`}>
            <div class={`${colors.bg} px-6 py-4`}>
              <div class={`font-bold text-sm uppercase tracking-wider ${colors.text}`}>{pilar.name}</div>
              <div class={`text-sm ${colors.text} mt-1`}>{pilar.tagline}</div>
            </div>
            <div class="p-6">
              <p class="text-sm text-gray-600 mb-6">{pilar.description}</p>
              <div class="space-y-3">
                {pilar.products.map((product) => (
                  <a href={`/${product.slug}`} class="flex items-center gap-3 group/item p-2 -mx-2 rounded-lg hover:bg-gray-50 transition">
                    <div class={`w-8 h-8 ${colors.bg} rounded-lg flex items-center justify-center flex-shrink-0`}>
                      <svg class={`w-4 h-4 ${colors.text}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                      </svg>
                    </div>
                    <div>
                      <div class={`text-sm font-semibold text-gray-900 group-hover/item:${colors.text} transition`}>{product.brand} - {product.name}</div>
                      <div class="text-xs text-gray-500">{product.shortDescription.substring(0, 60)}...</div>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<!-- Contact Info Section -->
<section class="py-16 sm:py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Info -->
      <div>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-6">
          {isEnglish ? `Contact Us in ${region.city}` : `Contáctenos en ${region.city}`}
        </h2>
        <p class="text-lg text-gray-600 mb-8">
          {isEnglish
            ? `Our team in ${region.city} is ready to help you protect your business. Contact us for a free consultation.`
            : `Nuestro equipo en ${region.city} está listo para ayudarle a proteger su empresa. Contáctenos para una consultoría gratuita.`}
        </p>

        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">{isEnglish ? 'Address' : 'Dirección'}</h3>
              <p class="text-gray-600">{region.address}</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">{isEnglish ? 'Phone' : 'Teléfono'}</h3>
              <a href={`tel:${region.phone}`} class="text-gray-600 hover:text-blue-600 transition">{region.phoneDisplay}</a>
              <p class="text-sm text-gray-500">{region.hours}</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">Email</h3>
              <a href={`mailto:${region.email}`} class="text-gray-600 hover:text-blue-600 transition">{region.email}</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="bg-white rounded-2xl shadow-lg p-8 border border-gray-200">
        <h3 class="text-xl font-bold text-gray-900 mb-6">
          {isEnglish ? 'Request a Free Consultation' : 'Solicite una Consultoria Gratuita'}
        </h3>
        <form action={`/${region.slug ? region.slug + '/gracias' : 'gracias'}`} method="GET" class="space-y-4">
          <input type="hidden" name="region" value={region.slug || 'colombia'} />
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="reg-nombre" class="block text-sm font-medium text-gray-700 mb-1">{isEnglish ? 'Name' : 'Nombre'}</label>
              <input type="text" id="reg-nombre" name="nombre" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent" />
            </div>
            <div>
              <label for="reg-email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
              <input type="email" id="reg-email" name="email" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent" />
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="reg-telefono" class="block text-sm font-medium text-gray-700 mb-1">{isEnglish ? 'Phone' : 'Teléfono'}</label>
              <input type="tel" id="reg-telefono" name="telefono" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent" />
            </div>
            <div>
              <label for="reg-empresa" class="block text-sm font-medium text-gray-700 mb-1">{isEnglish ? 'Company' : 'Empresa'}</label>
              <input type="text" id="reg-empresa" name="empresa" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent" />
            </div>
          </div>
          <div>
            <label for="reg-servicio" class="block text-sm font-medium text-gray-700 mb-1">{isEnglish ? 'Service of Interest' : 'Servicio de Interés'}</label>
            <select id="reg-servicio" name="servicio" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent bg-white">
              <option value="">{isEnglish ? 'Select a service' : 'Seleccione un servicio'}</option>
              {region.services.map((s) => (
                <option value={s}>{s}</option>
              ))}
            </select>
          </div>
          <div>
            <label for="reg-mensaje" class="block text-sm font-medium text-gray-700 mb-1">{isEnglish ? 'Message' : 'Mensaje'}</label>
            <textarea id="reg-mensaje" name="mensaje" rows="3" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent"></textarea>
          </div>
          <button type="submit" class="w-full bg-gradient-to-r from-red-500 to-red-600 text-white font-semibold py-4 rounded-lg hover:from-red-600 hover:to-red-700 transition shadow-lg">
            {isEnglish ? 'Send Request' : 'Enviar Solicitud'}
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- Why Choose Us -->
<section class="py-16 sm:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">
      {isEnglish ? `Why Choose Starsolution in ${region.city}?` : `¿Por qué Elegir Starsolution en ${region.city}?`}
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mt-12">
      <div class="text-center">
        <div class="w-16 h-16 bg-red-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <h3 class="font-bold text-gray-900 mb-2">{isEnglish ? 'Certified Team' : 'Equipo Certificado'}</h3>
        <p class="text-sm text-gray-600">{isEnglish ? 'CEH, OSCP, CISSP certified professionals' : 'Profesionales certificados CEH, OSCP, CISSP'}</p>
      </div>
      <div class="text-center">
        <div class="w-16 h-16 bg-blue-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="font-bold text-gray-900 mb-2">{isEnglish ? 'Local Presence' : 'Presencia Local'}</h3>
        <p class="text-sm text-gray-600">{isEnglish ? `Office in ${region.city} with local support` : `Oficina en ${region.city} con soporte local`}</p>
      </div>
      <div class="text-center">
        <div class="w-16 h-16 bg-green-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="font-bold text-gray-900 mb-2">{isEnglish ? '24/7 Support' : 'Soporte 24/7'}</h3>
        <p class="text-sm text-gray-600">{isEnglish ? 'Round-the-clock monitoring and response' : 'Monitoreo y respuesta las 24 horas'}</p>
      </div>
      <div class="text-center">
        <div class="w-16 h-16 bg-purple-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
        </div>
        <h3 class="font-bold text-gray-900 mb-2">{isEnglish ? '12+ Years Experience' : '12+ Años de Experiencia'}</h3>
        <p class="text-sm text-gray-600">{isEnglish ? 'Protecting businesses since 2013' : 'Protegiendo empresas desde 2013'}</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-16 bg-gradient-to-r from-gray-900 to-gray-800">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
      {isEnglish ? 'Ready to Protect Your Business?' : '¿Listo para Proteger su Empresa?'}
    </h2>
    <p class="text-lg text-gray-300 mb-8">
      {isEnglish
        ? `Contact our ${region.city} office today for a free security assessment.`
        : `Contacte nuestra oficina en ${region.city} hoy para una evaluación de seguridad gratuita.`}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href={`https://api.whatsapp.com/send/?phone=${region.whatsapp}&text&type=phone_number&app_absent=0`} target="_blank" rel="noopener noreferrer" class="bg-[#0d6e5b] text-white font-semibold px-8 py-4 rounded-full hover:bg-[#0e7a6e] transition shadow-lg flex items-center justify-center gap-2">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
        WhatsApp
      </a>
      <a href={`mailto:${region.email}`} class="bg-white text-gray-900 font-semibold px-8 py-4 rounded-full hover:bg-gray-100 transition shadow-lg">
        {region.email}
      </a>
    </div>
  </div>
</section>
